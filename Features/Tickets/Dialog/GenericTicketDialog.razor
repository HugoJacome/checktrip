@using CheckTrip.Web.Features.Tickets.Services
@using CheckTrip.Web.Infrastructure.Notifications
@using MudBlazor

@inject TicketService TicketService
@inject INotificationService Notifications

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">Crear boleto genérico</MudText>

            <MudAlert Severity="Severity.Info" Dense="true">
                Este boleto no queda asociado a una reserva. Se registra directamente para el bote, ruta/horario y fecha seleccionados.
            </MudAlert>

            <MudForm @ref="_form">
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField T="string"
                                      Label="Nombre del pasajero"
                                      @bind-Value="_passengerName"
                                      Required="true"
                                      RequiredError="El nombre del pasajero es obligatorio."
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Documento"
                                      @bind-Value="_documentNumber"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudSelect T="string"
                                   Label="Tipo de boleto"
                                   @bind-Value="_ticketType"
                                   Required="true"
                                   RequiredError="El tipo de boleto es obligatorio."
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            <MudSelectItem Value="@TicketTypeOutbound">Ida</MudSelectItem>
                            <MudSelectItem Value="@TicketTypeReturn">Retorno</MudSelectItem>
                            <MudSelectItem Value="@TicketTypeComplete">Completo</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudForm>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_saving">
            Cancelar
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="_saving"
                   OnClick="Save">
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid BoatId { get; set; }
    [Parameter] public Guid BoatRouteScheduleId { get; set; }
    [Parameter] public DateTime TripDate { get; set; }

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private const string TicketTypeOutbound = "Outbound";
    private const string TicketTypeReturn = "Return";
    private const string TicketTypeComplete = "Complete";

    private MudForm? _form;
    private bool _saving;

    private string _passengerName = string.Empty;
    private string? _documentNumber;
    private string _ticketType = TicketTypeOutbound;

    private async Task Save()
    {
        if (_form is null)
            return;

        await _form.Validate();

        if (!_form.IsValid)
            return;

        try
        {
            _saving = true;

            var passengerName = _passengerName.Trim();
            var documentNumber = string.IsNullOrWhiteSpace(_documentNumber)
                ? null
                : _documentNumber.Trim();

            if (_ticketType == TicketTypeComplete)
            {
                await CreateGenericTicketAsync(passengerName, documentNumber, TicketTypeOutbound);
                await CreateGenericTicketAsync(passengerName, documentNumber, TicketTypeReturn);

                Notifications.Success("Boletos genéricos de ida y retorno creados correctamente.");
            }
            else
            {
                await CreateGenericTicketAsync(passengerName, documentNumber, _ticketType);

                Notifications.Success("Boleto genérico creado correctamente.");
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private Task CreateGenericTicketAsync(
        string passengerName,
        string? documentNumber,
        string ticketType)
    {
        return TicketService.CreateGenericTicketAsync(
            BoatId,
            TripDate.Date,
            passengerName,
            documentNumber,
            ticketType,
            BoatRouteScheduleId);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}