@using CheckTrip.Web.Features.Tickets.Models
@using CheckTrip.Web.Features.Tickets.Services
@using CheckTrip.Web.Infrastructure.Notifications
@using MudBlazor

@inject TicketService TicketService
@inject INotificationService Notifications

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Boletos de la reserva</MudText>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ConfirmationNumber"
                           Disabled="_loading"
                           OnClick="Generate">
                    Generar boletos
                </MudButton>
            </MudStack>

            <MudTable Items="_tickets" Dense="true" Hover="true" Bordered="true" Loading="_loading">
                <HeaderContent>
                    <MudTh>Boleto</MudTh>
                    <MudTh>Documento</MudTh>
                    <MudTh>Pasajero</MudTh>
                    <MudTh>Viaje</MudTh>
                    <MudTh>Tipo</MudTh>
                    <MudTh>Impreso</MudTh>
                    <MudTh>Reimp.</MudTh>
                    <MudTh>Acciones</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd>@context.TicketNumber</MudTd>
                    <MudTd>@context.DocumentNumber</MudTd>
                    <MudTd>@context.PassengerName</MudTd>
                    <MudTd>@context.TripType</MudTd>
                    <MudTd>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.IsGeneric ? Color.Warning : Color.Info)">
                            @(context.IsGeneric ? "Genérico" : "Reserva")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.IsPrinted ? Color.Success : Color.Warning)">
                            @(context.IsPrinted ? "Sí" : "No")
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.ReprintCount</MudTd>
                    <MudTd>
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Text"
                                   Color="Color.Primary"
                                   Disabled="_loading"
                                   OnClick="@(() => MarkPrinted(context.Id))">
                            @(context.IsPrinted ? "Reimprimir" : "Imprimir")
                        </MudButton>
                    </MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <MudText>No existen boletos generados.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Close">Cerrar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid ReservationId { get; set; }

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private List<TicketListItem> _tickets = [];
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;

        try
        {
            _tickets = await TicketService.GetByReservationAsync(ReservationId);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Generate()
    {
        try
        {
            _loading = true;
            await TicketService.GenerateForReservationAsync(ReservationId);
            Notifications.Success("Boletos generados correctamente.");
            await Load();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task MarkPrinted(Guid ticketId)
    {
        try
        {
            _loading = true;
            await TicketService.MarkPrintedAsync(ticketId);
            Notifications.Success("Boleto actualizado correctamente.");
            await Load();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private void Close()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }
}