@using CheckTrip.Web.Features.Reservations.Models.Operations
@using CheckTrip.Web.Features.Reservations.Services
@using CheckTrip.Web.Infrastructure.Notifications
@using MudBlazor

@inject ReservationService ReservationService
@inject INotificationService Notifications

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudSelect T="string"
                       Label="Tipo de comentario"
                       @bind-Value="_model.CommentType">
                <MudSelectItem Value="@("General")">General</MudSelectItem>
                <MudSelectItem Value="@("Payment")">Pago</MudSelectItem>
                <MudSelectItem Value="@("Agency")">Agencia</MudSelectItem>
                <MudSelectItem Value="@("Operation")">Operación</MudSelectItem>
            </MudSelect>

            <MudSelect T="string"
                       Label="Estado de pago"
                       @bind-Value="_model.PaymentStatus"
                       Clearable="true">
                <MudSelectItem Value="@("Pending")">Pendiente</MudSelectItem>
                <MudSelectItem Value="@("Partial")">Parcial</MudSelectItem>
                <MudSelectItem Value="@("Paid")">Pagado</MudSelectItem>
            </MudSelect>

            <MudTextField Label="Comentario"
                          Lines="4"
                          @bind-Value="_model.Comment"
                          Required="true" />
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">
            Cancelar
        </MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="_saving"
                   OnClick="SaveAsync">
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid ReservationId { get; set; }

    private bool _saving;

    private AddReservationCommentModel _model = new()
    {
        CommentType = "General"
    };

    protected override void OnInitialized()
    {
        _model.ReservationId = ReservationId;
    }

    private async Task SaveAsync()
    {
        try
        {
            _saving = true;

            await ReservationService.AddCommentAsync(_model);

            Notifications.Success("Comentario guardado.");
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}