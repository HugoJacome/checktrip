@using CheckTrip.Web.Features.Reservations.Models
@using CheckTrip.Web.Features.Reservations.Services
@using MudBlazor

@inject ReservationService Service

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">Buscar / Registrar Pasajero</MudText>

            <MudTextField T="string"
                          Label="Buscar por identificación o nombre"
                          @bind-Value="_search"
                          Immediate="true"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          OnAdornmentClick="SearchAsync" />

            <MudButton Variant="Variant.Outlined" OnClick="SearchAsync">
                Buscar
            </MudButton>

            @if (_results.Any())
            {
                <MudTable Items="_results" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Documento</MudTh>
                        <MudTh>Nombre</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.DocumentNumber</MudTd>
                        <MudTd>@context.FullName</MudTd>
                        <MudTd>
                            <MudButton Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="@(() => Select(context))">
                                Seleccionar
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }

            <MudDivider />

            <MudText Typo="Typo.subtitle1">Registrar nuevo pasajero</MudText>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" Label="Tipo documento" @bind-Value="_new.DocumentType">
                        <MudSelectItem Value="@("Cedula")">Cédula</MudSelectItem>
                        <MudSelectItem Value="@("Pasaporte")">Pasaporte</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField Label="Identificación" @bind-Value="_new.DocumentNumber" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField Label="Nombre completo" @bind-Value="_new.FullName" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField Label="Nacionalidad" @bind-Value="_new.Nationality" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Fecha nacimiento" @bind-Date="_new.BirthDate" />
                </MudItem>
            </MudGrid>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Create">
            Agregar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private string? _search;
    private List<CustomerLookupModel> _results = [];
    private CustomerUpsertModel _new = new();

    private async Task SearchAsync()
    {
        _results = await Service.SearchCustomersAsync(_search ?? "");
    }

    private void Select(CustomerLookupModel customer)
    {
        var passenger = new ReservationPassengerModel
        {
            DocumentType = customer.DocumentType,
            DocumentNumber = customer.DocumentNumber,
            FullName = customer.FullName,
            Age = customer.Age,
            PassengerType = "Adult",
            Outbound = true,
            Return = true
        };

        MudDialog.Close(DialogResult.Ok(passenger));
    }

    private void Create()
    {
        var passenger = new ReservationPassengerModel
        {
            DocumentType = _new.DocumentType,
            DocumentNumber = _new.DocumentNumber,
            FullName = _new.FullName,
            Nationality = _new.Nationality,
            BirthDate = _new.BirthDate,
            Age = _new.Age,
            PassengerType = "Adult",
            Outbound = true,
            Return = true
        };

        MudDialog.Close(DialogResult.Ok(passenger));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}