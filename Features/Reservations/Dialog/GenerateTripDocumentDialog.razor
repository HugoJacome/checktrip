@using CheckTrip.Web.Features.Reservations.Models.Operations
@using CheckTrip.Web.Features.Tickets.Services
@using CheckTrip.Web.Infrastructure.Notifications
@using Microsoft.JSInterop
@using MudBlazor

@inject BoatDailyTripService BoatDailyTripService
@inject INotificationService Notifications
@inject IJSRuntime JS

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Info" Dense="true">
                Revise o modifique la tripulación del viaje antes de generar el documento.
            </MudAlert>

            <MudForm @ref="_form">
                <MudGrid>
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2">Capitán</MudText>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField Label="Nombre capitán"
                                      @bind-Value="_model.CaptainName"
                                      Required="true"
                                      RequiredError="El capitán es obligatorio."
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField Label="Cédula capitán"
                                      @bind-Value="_model.CaptainDocument"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudDivider />
                        <MudText Typo="Typo.subtitle2">Marineros</MudText>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField Label="Marinero 1"
                                      @bind-Value="_model.Sailor1Name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField Label="Cédula marinero 1"
                                      @bind-Value="_model.Sailor1Document"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField Label="Marinero 2"
                                      @bind-Value="_model.Sailor2Name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField Label="Cédula marinero 2"
                                      @bind-Value="_model.Sailor2Document"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField Label="Marinero 3"
                                      @bind-Value="_model.Sailor3Name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField Label="Cédula marinero 3"
                                      @bind-Value="_model.Sailor3Document"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField Label="Observación"
                                      Lines="3"
                                      @bind-Value="_model.Notes"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_saving">
            Cancelar
        </MudButton>

        <MudButton Color="Color.Success"
                   Variant="Variant.Filled"
                   Disabled="_saving"
                   OnClick="SaveAsync">
            Generar documento
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid BoatId { get; set; }
    [Parameter] public Guid BoatRouteScheduleId { get; set; }
    [Parameter] public DateTime TripDate { get; set; }

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm? _form;
    private bool _saving;

    private GenerateTripDocumentModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        _model = await BoatDailyTripService.GetGenerateDocumentModelAsync(
            BoatId,
            BoatRouteScheduleId,
            TripDate);
    }

    private async Task SaveAsync()
    {
        if (_form is null)
            return;

        await _form.Validate();

        if (!_form.IsValid)
            return;

        try
        {
            _saving = true;

            var result = await BoatDailyTripService.GenerateDocumentWithCrewAsync(_model);

            await JS.InvokeVoidAsync(
                "checkTripDownloadFile",
                result.FileName,
                result.ContentType,
                Convert.ToBase64String(result.Content));

            Notifications.Success($"Documento generado: {result.DocumentNumber}");
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}