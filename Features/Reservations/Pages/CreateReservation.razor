@page "/reservations/create"
@page "/reservations/create/{ReservationId:guid}"

@using CheckAccess.Features.Reservations.Dialog
@using CheckTrip.Web.Features.Reservations.Models
@using CheckTrip.Web.Features.Reservations.Services
@using CheckTrip.Web.Infrastructure.Notifications
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using ClosedXML.Excel
@using System.Globalization

@inject ReservationService Service
@inject BoatService BoatService
@inject AgencyService AgencyService
@inject SellerService SellerService
@inject RouteService RouteService
@inject IDialogService Dialog
@inject INotificationService Notifications
@inject NavigationManager Navigation

<style>
    .ct-availability-panel {
        border-radius: 18px;
    }

    .ct-availability-header {
        gap: 16px;
        flex-wrap: wrap;
    }

    .ct-availability-title {
        color: #355080;
        font-weight: 500;
    }

    .ct-availability-subtitle {
        color: #6b7280;
    }

    .ct-days-wrapper {
        display: flex;
        gap: 14px;
        justify-content: space-between;
        align-items: stretch;
        width: 100%;
        margin-top: 18px;
        overflow-x: auto;
        padding-bottom: 4px;
    }

    .ct-day-card {
        flex: 1 1 0;
        min-width: 170px;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 12px;
        background: #fff;
    }

    .ct-day-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 8px;
        margin-bottom: 10px;
        border-bottom: 1px solid #eef0f4;
    }

    .ct-day-name {
        font-weight: 700;
        color: #111827;
    }

    .ct-day-date {
        font-size: 12px;
        color: #6b7280;
    }

    .ct-empty-day {
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px dashed #d1d5db;
        border-radius: 12px;
        color: #9ca3af;
        font-size: 13px;
    }

    .ct-slot-button {
        min-height: 64px;
        border-radius: 14px;
        padding: 10px 12px;
        justify-content: flex-start;
        text-align: left;
        border: 1px solid #e5e7eb;
        background: #f9fafb;
        margin-bottom: 8px;
    }

        .ct-slot-button:hover {
            background: #eef6ff;
            border-color: #7aa7e8;
        }

    .ct-slot-selected {
        background: #dceeff !important;
        border: 2px solid #5578c2 !important;
    }

    .ct-slot-full {
        opacity: .55;
        background: #f3f4f6 !important;
    }

    .ct-slot-content {
        width: 100%;
    }

    .ct-slot-time {
        font-weight: 800;
        font-size: 15px;
        color: #111827;
    }

    .ct-slot-capacity {
        font-size: 12px;
        font-weight: 600;
        color: #374151;
        margin-top: 4px;
    }

    .ct-passenger-adult {
        background-color: #f3f4f6;
    }

    .ct-passenger-infant {
        background-color: #dcfce7;
    }

    .ct-passenger-courtesy {
        background-color: #e0f2fe;
    }

    @@media (max-width: 900px) {
        .ct-days-wrapper {
            justify-content: flex-start;
        }

        .ct-day-card {
            flex: 0 0 220px;
        }
    }
</style>

<MudStack Spacing="3">

    <MudStack Row="true"
              AlignItems="AlignItems.Center"
              Justify="Justify.SpaceBetween"
              Class="mb-2">

        <MudText Typo="Typo.h5">
            @(_isEditMode ? "Editar reserva" : "Nueva reserva")
        </MudText>

        @if (_isEditMode)
        {
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="BackToMonitor">
                Atrás
            </MudButton>
        }
    </MudStack>
    <MudText Typo="Typo.body2">
        Seleccione la lancha, la ruta disponible, cargue los pasajeros y confirme la reserva.
    </MudText>

    <MudPaper Class="pa-4">
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudTextField Label="ID"
                              Value="@("Generado automáticamente")"
                              Disabled="true" />
            </MudItem>

            <MudItem xs="12" md="3">
                <MudTextField Label="Código referencial"
                              @bind-Value="_model.ExternalReference" />
            </MudItem>

            <MudItem xs="12" md="3">
                <MudSelect T="Guid?" Label="Agencia" @bind-Value="_model.AgencyId" Clearable="true">
                    @foreach (var a in _agencies)
                    {
                        <MudSelectItem T="Guid?" Value="@a.Id">@a.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="3">
                <MudSelect T="Guid?" Label="Vendedor" @bind-Value="_model.SellerId" Clearable="true">
                    @foreach (var s in _sellers)
                    {
                        <MudSelectItem T="Guid?" Value="@s.Id">@s.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="3">
                <MudSelect T="Guid?"
                           Label="Ruta"
                           Value="_routeId"
                           ValueChanged="OnRouteChanged"
                           Clearable="true">
                    @foreach (var r in _routes)
                    {
                        <MudSelectItem T="Guid?" Value="@r.Id">
                            @($"{r.Origin} - {r.Destination}")
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="3">
                <MudSelect T="Guid?"
                           Label="Lancha"
                           Value="_boatId"
                           ValueChanged="OnBoatChanged"
                           Clearable="true"
                           Disabled="@(!_routeId.HasValue)">
                    @foreach (var b in _boats)
                    {
                        <MudSelectItem T="Guid?" Value="@b.Id">@b.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="2">
                <MudNumericField T="int" Label="Adultos" @bind-Value="_adultCount" Min="0" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudNumericField T="int" Label="Infantes" @bind-Value="_infantCount" Min="0" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudNumericField T="int" Label="Cortesías" @bind-Value="_courtesyCount" Min="0" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 ct-availability-panel">
        <MudStack Row="true"
                  Justify="Justify.SpaceBetween"
                  AlignItems="AlignItems.Center"
                  Class="ct-availability-header">

            <MudStack Spacing="1">
                <MudText Typo="Typo.h6">
                    Disponibilidad semanal
                    @if (!string.IsNullOrWhiteSpace(AvailabilityTitle))
                    {
                        <span class="ct-availability-title">· @AvailabilityTitle</span>
                    }
                </MudText>

                <MudText Typo="Typo.caption" Class="ct-availability-subtitle">
                    Seleccione el día y horario disponible. Cada pasajero puede viajar solo ida, solo regreso o ambos.
                </MudText>
            </MudStack>

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Disabled="@(!_boatId.HasValue || !_routeId.HasValue)"
                           OnClick="PreviousWeek">
                    Semana anterior
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Disabled="@(!_boatId.HasValue || !_routeId.HasValue)"
                           OnClick="NextWeek">
                    Semana siguiente
                </MudButton>
            </MudStack>
        </MudStack>

        @if (!_routeId.HasValue)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3">
                Seleccione una ruta para cargar las lanchas disponibles.
            </MudAlert>
        }
        else if (!_boatId.HasValue)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3">
                Seleccione una lancha para cargar la disponibilidad semanal.
            </MudAlert>
        }
        else
        {
            <div class="ct-days-wrapper">
                @foreach (var day in WeekDays)
                {
                    var dayItems = GetDayItems(day).ToList();

                    <MudPaper Class="ct-day-card" Elevation="0">
                        <div class="ct-day-header">
                            <span class="ct-day-name">@GetDayName(day)</span>
                            <span class="ct-day-date">@day.ToString("dd/MM")</span>
                        </div>

                        @if (!dayItems.Any())
                        {
                            <div class="ct-empty-day">
                                Sin horarios
                            </div>
                        }
                        else
                        {
                            @foreach (var item in dayItems)
                            {
                                <MudButton FullWidth="true"
                                           Variant="Variant.Text"
                                           Disabled="@(item.IsFull || item.TravelDate.Date < DateTime.Today)"
                                           Class="@GetAvailabilityClass(item)"
                                           OnClick="@(() => SelectTrip(item))">
                                    <div class="ct-slot-content">
                                        <div class="ct-slot-time">@item.Schedule</div>
                                        <div class="ct-slot-capacity">
                                            @item.Available cupos disponibles
                                        </div>
                                    </div>
                                </MudButton>
                            }
                        }
                    </MudPaper>
                }
            </div>
        }
    </MudPaper>

    <MudPaper Class="pa-4">
        <MudText Typo="Typo.subtitle1">Viaje seleccionado</MudText>

        @if (_selectedTrip is null)
        {
            <MudAlert Severity="Severity.Info">
                Seleccione un día y horario disponible.
            </MudAlert>
        }
        else
        {
            <MudText>
                @_selectedTrip.TravelDate.ToString("dd/MM/yyyy") -
                @_selectedTrip.Schedule -
                @_selectedTrip.Route -
                @_selectedTrip.Boat
            </MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6">Listado de pasajeros</MudText>

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           OnClick="AddGenericPassenger">
                    Agregar genérico
                </MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="AddPassengerDialog">
                    Buscar / registrar
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Info"
                           HtmlTag="label"
                           for="passenger-excel">
                    Cargar Excel
                </MudButton>

                <InputFile id="passenger-excel"
                           OnChange="LoadPassengersFromExcel"
                           accept=".xlsx"
                           style="display:none" />
            </MudStack>
        </MudStack>

        <MudTable Items="_model.Passengers.Where(x => !x.IsCancelled)"
                  Dense="true"
                  Hover="true"
                  Bordered="true"
                  Class="mt-3"
                  RowClassFunc="GetPassengerRowClass">
            <HeaderContent>
                <MudTh>N°</MudTh>
                <MudTh>Identificación</MudTh>
                <MudTh>Nombres completos</MudTh>
                <MudTh>Nacionalidad</MudTh>
                <MudTh>Edad</MudTh>
                <MudTh>Tipo pasajero</MudTh>
                <MudTh>Ida</MudTh>
                <MudTh>Regreso</MudTh>
                <MudTh>Fecha retorno</MudTh>
                <MudTh></MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd>@(_model.Passengers.IndexOf(context) + 1)</MudTd>

                <MudTd>
                    <MudTextField T="string"
                                  Value="context.DocumentNumber"
                                  ValueChanged="@((string value) => OnPassengerDocumentChangedAsync(context, value))"
                                  Dense="true"
                                  Disabled="@context.IsGenericPassenger"
                                  Placeholder="@(context.IsGenericPassenger ? "GENÉRICO" : null)" />
                </MudTd>

                <MudTd>
                    <MudTextField T="string"
                                  Value="context.FullName"
                                  ValueChanged="@((string value) => OnPassengerFullNameChanged(context, value))"
                                  Dense="true"
                                  Placeholder="@(context.IsGenericPassenger ? "Pasajero genérico" : null)" />
                </MudTd>

                <MudTd>
                    <MudSelect T="string"
                               Value="context.Nationality"
                               ValueChanged="@((string value) => OnPassengerNationalityChanged(context, value))"
                               Dense="true">
                        @foreach (var nationality in _nationalities)
                        {
                            <MudSelectItem Value="@nationality">@nationality</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>

                <MudTd>
                    <MudNumericField T="int?"
                                     Value="context.Age"
                                     ValueChanged="@((int? value) => OnPassengerAgeChanged(context, value))"
                                     Dense="true"
                                     Min="0"
                                     Max="120" />
                </MudTd>

                <MudTd>
                    <MudSelect T="string"
                               Value="context.PassengerType"
                               ValueChanged="@((string value) => OnPassengerTypeChanged(context, value))"
                               Dense="true"
                               Disabled="@(context.Age <= 1)">
                        @if (context.Age <= 1)
                        {
                            <MudSelectItem Value="@("Infant")">Infante</MudSelectItem>
                        }
                        else
                        {
                            <MudSelectItem Value="@("Adult")">Adulto</MudSelectItem>
                            <MudSelectItem Value="@("Courtesy")">Cortesía</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>

                <MudTd>
                    <MudCheckBox T="bool"
                                 Value="context.Outbound"
                                 ValueChanged="@((bool value) => context.Outbound = value)"
                                 Dense="true" />
                </MudTd>

                <MudTd>
                    <MudCheckBox T="bool"
                                 Value="context.Return"
                                 ValueChanged="@((bool value) => OnPassengerReturnChanged(context, value))"
                                 Dense="true" />
                </MudTd>

                <MudTd>
                    <MudDatePicker Date="context.ReturnDate"
                                   DateChanged="@((DateTime? value) => OnPassengerReturnDateChanged(context, value))"
                                   DateFormat="dd/MM/yyyy"
                                   Dense="true"
                                   Disabled="@(!context.Return)" />
                </MudTd>

                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Disabled="@context.IsCancelled"
                                   OnClick="@(() => RemovePassenger(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz"
                                   Color="Color.Primary"
                                   Disabled="@(!IsEditMode || context.IsCancelled)"
                                   OnClick="@(() => ReplacePassenger(context))" />
                </MudTd>
            </RowTemplate>

            <NoRecordsContent>
                <MudText>No existen pasajeros agregados.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>

    <MudStack Row="true" Justify="Justify.FlexEnd">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@IsSaveDisabled"
                   OnClick="Save">
            Guardar reserva
        </MudButton>
    </MudStack>
</MudStack>

@code {

    [Parameter] public Guid? ReservationId { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private CreateReservationModel _model = new();

    private List<BoatListItem> _boats = [];
    private List<RouteListItem> _routes = [];
    private List<AgencyListItem> _agencies = [];
    private List<SellerListItem> _sellers = [];
    private List<WeeklyAvailabilityItem> _weekly = [];
    private bool _isEditMode => ReservationId.HasValue && ReservationId.Value != Guid.Empty;
    private bool IsEditMode => ReservationId.HasValue;
    private string PageTitle => _isEditMode ? "Editar reserva" : "Nueva reserva";
    private DateTime? CurrentOutboundDate =>
    _model.OutboundDate?.Date ?? _selectedTrip?.TravelDate.Date;

    private void BackToMonitor()
    {
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
            Navigation.NavigateTo(ReturnUrl);
        else
            Navigation.NavigateTo("/reservations/monitor");
    }
    private readonly List<string> _nationalities =
    [
        "Ecuatoriana",
        "Colombiana",
        "Peruana",
        "Argentina",
        "Chilena",
        "Venezolana",
        "Estadounidense",
        "Española",
        "Mexicana",
        "Otra"
    ];

    private Guid? _boatId;
    private Guid? _routeId;

    private DateTime _weekStart = GetStartOfWeek(DateTime.Today);
    private WeeklyAvailabilityItem? _selectedTrip;

    private int _adultCount = 1;
    private int _infantCount;
    private int _courtesyCount;

    private bool _saving;

    private bool IsSaveDisabled =>
        _saving ||
        _selectedTrip is null ||
        !_model.Passengers.Any();


    private IEnumerable<DateTime> WeekDays =>
        Enumerable.Range(0, 7).Select(x => _weekStart.AddDays(x));

    protected override async Task OnInitializedAsync()
    {
        _routes = await RouteService.GetAllAsync();
        _agencies = await AgencyService.GetAllAsync();
        _sellers = await SellerService.GetAllAsync();

        if (ReservationId.HasValue)
            await LoadReservationForEdit(ReservationId.Value);
        else
            _weekly.Clear();
    }

    private async Task OnBoatChanged(Guid? value)
    {
        _boatId = value;
        _selectedTrip = null;
        _weekly.Clear();

        await LoadWeeklyAvailability();
    }
    private async Task LoadReservationForEdit(Guid reservationId)
    {
        var edit = await Service.GetForEditAsync(reservationId);

        if (edit is null)
        {
            Notifications.Error("Reserva no encontrada.");
            Navigation.NavigateTo("/reservations/monitor");
            return;
        }

        _model = edit;

        var firstScheduleId = _model.OutboundRouteScheduleId;

        if (firstScheduleId.HasValue)
        {
            var schedule = await Service.GetRouteScheduleInfoAsync(firstScheduleId.Value);

            _routeId = schedule.RouteId;
            _boatId = schedule.BoatId;

            _boats = await Service.GetBoatsByRouteAsync(_routeId.Value);

            if (_model.OutboundDate.HasValue)
                _weekStart = GetStartOfWeek(_model.OutboundDate.Value);

            await LoadWeeklyAvailability();

            _selectedTrip = _weekly.FirstOrDefault(x =>
                x.BoatRouteScheduleId == firstScheduleId.Value &&
                x.TravelDate.Date == _model.OutboundDate!.Value.Date);
        }

        SyncPassengerCountersFromList();
    }

    private async Task OnRouteChanged(Guid? value)
    {
        _routeId = value;
        _boatId = null;
        _selectedTrip = null;
        _boats.Clear();
        _weekly.Clear();

        if (!_routeId.HasValue)
            return;

        _boats = await Service.GetBoatsByRouteAsync(_routeId.Value);
    }

    private async Task PreviousWeek()
    {
        _weekStart = GetStartOfWeek(_weekStart.AddDays(-7));
        _selectedTrip = null;

        await LoadWeeklyAvailability();
    }

    private async Task NextWeek()
    {
        _weekStart = GetStartOfWeek(_weekStart.AddDays(7));
        _selectedTrip = null;

        await LoadWeeklyAvailability();
    }

    private async Task LoadWeeklyAvailability()
    {
        if (!_boatId.HasValue || !_routeId.HasValue)
        {
            _weekly.Clear();
            return;
        }

        var data = await Service.GetWeeklyAvailabilityAsync(
            _weekStart,
            _boatId,
            _routeId);

        _weekly = data
            .GroupBy(x => new
            {
                x.BoatRouteScheduleId,
                Date = x.TravelDate.Date
            })
            .Select(x => x.First())
            .OrderBy(x => x.TravelDate)
            .ThenBy(x => x.Schedule)
            .ToList();
    }

    private IEnumerable<WeeklyAvailabilityItem> GetDayItems(DateTime day)
    {
        return _weekly
            .Where(x => x.TravelDate.Date == day.Date)
            .GroupBy(x => new
            {
                x.BoatRouteScheduleId,
                Date = x.TravelDate.Date
            })
            .Select(x => x.First())
            .OrderBy(x => x.Schedule);
    }

    private void SelectTrip(WeeklyAvailabilityItem item)
    {
        if (item.TravelDate.Date < DateTime.Today)
        {
            Notifications.Error("Solo puede registrar reservas desde el día actual en adelante.");
            return;
        }

        if (item.IsFull)
        {
            Notifications.Error("Este viaje no tiene cupos disponibles.");
            return;
        }

        _selectedTrip = item;

        _model.OutboundRouteScheduleId = item.BoatRouteScheduleId;
        _model.OutboundDate = item.TravelDate.Date;

        foreach (var passenger in _model.Passengers.Where(x => x.Return))
        {
            if (!passenger.ReturnDate.HasValue || passenger.ReturnDate.Value.Date < _model.OutboundDate.Value.Date)
                passenger.ReturnDate = _model.OutboundDate.Value.Date;
        }

        StateHasChanged();
    }

    private async Task AddPassengerDialog()
    {
        var dialog = await Dialog.ShowAsync<CustomerSearchDialog>("Pasajero");
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is ReservationPassengerModel passenger)
        {
            if (IsDuplicatedDocument(passenger.DocumentNumber, passenger))
            {
                Notifications.Error($"Ya existe un pasajero con la identificación {passenger.DocumentNumber}.");
                return;
            }

            if (string.IsNullOrWhiteSpace(passenger.Nationality))
                passenger.Nationality = "Ecuatoriana";

            if (passenger.Return)
                passenger.ReturnDate = _model.OutboundDate?.Date;

            passenger.IsNewCustomer = !passenger.CustomerId.HasValue;
            passenger.CustomerChanged = passenger.IsNewCustomer;

            ApplyPassengerTypeByAge(passenger);

            _model.Passengers.Add(passenger);
            SyncPassengerCountersFromList();
        }
    }

    private async Task RemovePassenger(ReservationPassengerModel passenger)
    {
        if (IsEditMode && passenger.ReservationItemId.HasValue)
        {
            passenger.IsCancelled = true;
            ClearPassengerRow(passenger);

            Notifications.Success("Pasajero retirado de la edición. Al guardar se actualizarán los segmentos de la reserva.");
        }
        else
        {
            _model.Passengers.Remove(passenger);
        }

        SyncPassengerCountersFromList();

        await Task.CompletedTask;
    }

    private async Task OnPassengerDocumentChangedAsync(
    ReservationPassengerModel passenger,
    string value)
    {
        var text = value?.Trim() ?? string.Empty;

        passenger.DocumentNumber = text;

        if (string.IsNullOrWhiteSpace(text))
        {
            ClearPassengerCustomerData(passenger);
            SyncPassengerCountersFromList();
            return;
        }

        await OpenCustomerSearchDialogAsync(passenger, text);
    }

    private void OnPassengerAgeChanged(ReservationPassengerModel passenger, int? value)
    {
        passenger.Age = value;
        passenger.CustomerChanged = true;

        ApplyPassengerTypeByAge(passenger);
        SyncPassengerCountersFromList();
    }

    private void OnPassengerTypeChanged(ReservationPassengerModel passenger, string value)
    {
        if (passenger.Age <= 1)
        {
            passenger.PassengerType = "Infant";
            Notifications.Info("El tipo Infante se asigna automáticamente por edad.");
            SyncPassengerCountersFromList();
            return;
        }

        if (value != "Adult" && value != "Courtesy")
        {
            passenger.PassengerType = "Adult";
            Notifications.Error("Solo puede seleccionar Adulto o Cortesía.");
            SyncPassengerCountersFromList();
            return;
        }

        passenger.PassengerType = value;
        SyncPassengerCountersFromList();
    }
    private async Task OnPassengerFullNameChanged(
        ReservationPassengerModel passenger,
        string value)
    {
        passenger.FullName = value;
        passenger.CustomerChanged = true;

        if (!string.IsNullOrWhiteSpace(value) && value.Trim().Length >= 3)
            await OpenCustomerSearchDialogAsync(passenger, value.Trim());
    }

    private void OnPassengerNationalityChanged(ReservationPassengerModel passenger, string value)
    {
        passenger.Nationality = value;
        passenger.CustomerChanged = true;
    }

    private void OnPassengerReturnChanged(ReservationPassengerModel passenger, bool value)
    {
        passenger.Return = value;

        if (value)
        {
            passenger.ReturnDate = _model.OutboundDate?.Date
                                   ?? _selectedTrip?.TravelDate.Date
                                   ?? DateTime.Today;
        }
        else
        {
            passenger.ReturnDate = null;
        }
    }

    private void OnPassengerReturnDateChanged(ReservationPassengerModel passenger, DateTime? value)
    {
        if (!passenger.Return)
        {
            passenger.ReturnDate = null;
            return;
        }

        var outboundDate = CurrentOutboundDate;

        if (!outboundDate.HasValue)
        {
            passenger.ReturnDate = value?.Date;
            return;
        }

        if (value.HasValue && value.Value.Date < outboundDate.Value.Date)
        {
            Notifications.Error("La fecha de retorno no puede ser menor a la fecha de ida.");
            passenger.ReturnDate = outboundDate.Value.Date;
            return;
        }

        passenger.ReturnDate = value?.Date;
    }

    private void ApplyPassengerTypeByAge(ReservationPassengerModel passenger)
    {
        if (passenger.Age <= 1)
        {
            passenger.PassengerType = "Infant";
            return;
        }

        if (string.IsNullOrWhiteSpace(passenger.PassengerType) || passenger.PassengerType == "Infant")
            passenger.PassengerType = "Adult";
    }

    private bool IsDuplicatedDocument(string? documentNumber, ReservationPassengerModel current)
    {
        if (current.IsGenericPassenger)
            return false;

        if (string.IsNullOrWhiteSpace(documentNumber))
            return false;

        return _model.Passengers.Any(x =>
            !ReferenceEquals(x, current) &&
            !x.IsGenericPassenger &&
            !string.IsNullOrWhiteSpace(x.DocumentNumber) &&
            x.DocumentNumber.Trim().Equals(documentNumber.Trim(), StringComparison.OrdinalIgnoreCase));
    }

    private void ClearPassengerCustomerData(ReservationPassengerModel passenger)
    {
        passenger.CustomerId = null;
        passenger.FullName = string.Empty;
        passenger.Nationality = "Ecuatoriana";
        passenger.Age = null;
        passenger.PassengerType = "Adult";
        passenger.IsNewCustomer = true;
        passenger.CustomerChanged = true;
    }

    private async Task LoadPassengersFromExcel(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;

            if (file is null)
            {
                Notifications.Error("Seleccione un archivo Excel.");
                return;
            }

            if (!Path.GetExtension(file.Name).Equals(".xlsx", StringComparison.OrdinalIgnoreCase))
            {
                Notifications.Error("El archivo debe estar en formato .xlsx.");
                return;
            }

            const long maxSize = 2 * 1024 * 1024;

            if (file.Size > maxSize)
            {
                Notifications.Error("El archivo no debe superar los 2 MB.");
                return;
            }

            await using var stream = file.OpenReadStream(maxSize);

            using var memoryStream = new MemoryStream();

            await stream.CopyToAsync(memoryStream);

            memoryStream.Position = 0;

            using var workbook = new XLWorkbook(memoryStream);

            var worksheet = workbook.Worksheets.FirstOrDefault();

            if (worksheet is null)
            {
                Notifications.Error("El archivo Excel no contiene hojas.");
                return;
            }

            ValidateExcelHeaders(worksheet);

            var passengers = new List<ReservationPassengerModel>();
            var errors = new List<string>();

            var lastRow = worksheet.LastRowUsed()?.RowNumber() ?? 1;

            if (lastRow < 2)
            {
                Notifications.Error("El archivo no contiene pasajeros.");
                return;
            }

            for (var row = 2; row <= lastRow; row++)
            {
                var documentType = GetCellText(worksheet, row, 1);
                var documentNumber = GetCellText(worksheet, row, 2);
                var fullName = GetCellText(worksheet, row, 3);
                var nationality = GetCellText(worksheet, row, 4);
                var ageText = GetCellText(worksheet, row, 5);
                var passengerTypeText = GetCellText(worksheet, row, 6);
                var outboundText = GetCellText(worksheet, row, 7);
                var returnText = GetCellText(worksheet, row, 8);
                var returnDateText = GetCellText(worksheet, row, 9);

                if (IsEmptyRow(
                    documentType,
                    documentNumber,
                    fullName,
                    nationality,
                    ageText,
                    passengerTypeText,
                    outboundText,
                    returnText,
                    returnDateText))
                {
                    continue;
                }

                if (string.IsNullOrWhiteSpace(documentType))
                    errors.Add($"Fila {row}: el tipo de documento es obligatorio.");

                if (!TryMapDocumentType(documentType, out var normalizedDocumentType))
                    errors.Add($"Fila {row}: el tipo de documento debe ser Cédula o Pasaporte.");

                if (string.IsNullOrWhiteSpace(documentNumber))
                    errors.Add($"Fila {row}: el número de documento es obligatorio.");

                if (string.IsNullOrWhiteSpace(fullName))
                    errors.Add($"Fila {row}: los nombres y apellidos son obligatorios.");

                if (string.IsNullOrWhiteSpace(nationality))
                    errors.Add($"Fila {row}: la nacionalidad es obligatoria.");

                if (!_nationalities.Contains(nationality, StringComparer.OrdinalIgnoreCase))
                    errors.Add($"Fila {row}: la nacionalidad '{nationality}' no existe en el catálogo.");

                if (!int.TryParse(ageText, out var age))
                    errors.Add($"Fila {row}: la edad debe ser numérica.");

                if (age < 0 || age > 120)
                    errors.Add($"Fila {row}: la edad no es válida.");

                if (!TryMapPassengerType(passengerTypeText, out var passengerType))
                    errors.Add($"Fila {row}: el tipo de pasajero debe ser Adulto, Infante o Cortesía.");

                if (!TryParseBit(outboundText, out var outbound))
                    errors.Add($"Fila {row}: el campo Viaja ida debe ser 1 o 0.");

                if (!TryParseBit(returnText, out var passengerReturn))
                    errors.Add($"Fila {row}: el campo Viaja regreso debe ser 1 o 0.");

                DateTime? returnDate = null;

                if (passengerReturn)
                {
                    if (!string.IsNullOrWhiteSpace(returnDateText))
                    {
                        if (!TryParseDate(worksheet, row, 9, returnDateText, out returnDate))
                            errors.Add($"Fila {row}: la fecha de retorno no es válida.");
                    }
                    else
                    {
                        returnDate = _model.OutboundDate?.Date;
                    }

                    if (_model.OutboundDate.HasValue &&
                        returnDate.HasValue &&
                        returnDate.Value.Date < _model.OutboundDate.Value.Date)
                    {
                        errors.Add($"Fila {row}: la fecha de retorno no puede ser menor a la fecha de ida.");
                    }
                }

                if (age <= 1)
                {
                    passengerType = "Infant";
                }
                else if (passengerType == "Infant")
                {
                    passengerType = "Adult";
                }

                if (errors.Any(x => x.StartsWith($"Fila {row}:")))
                    continue;

                passengers.Add(new ReservationPassengerModel
                {
                    DocumentType = normalizedDocumentType,
                    DocumentNumber = documentNumber.Trim(),
                    FullName = fullName.Trim(),
                    Nationality = NormalizeNationality(nationality),
                    Age = age,
                    PassengerType = passengerType,
                    Outbound = outbound,
                    Return = passengerReturn,
                    ReturnDate = passengerReturn ? returnDate : null,
                    IsNewCustomer = true,
                    CustomerChanged = true
                });
            }

            if (errors.Any())
            {
                Notifications.Error(string.Join(" ", errors.Take(5)));

                if (errors.Count > 5)
                    Notifications.Error($"Existen {errors.Count - 5} errores adicionales.");

                return;
            }

            if (!passengers.Any())
            {
                Notifications.Error("No se encontraron pasajeros válidos en el archivo.");
                return;
            }

            var duplicatedDocuments = passengers
                .GroupBy(x => x.DocumentNumber.Trim(), StringComparer.OrdinalIgnoreCase)
                .Where(x => x.Count() > 1)
                .Select(x => x.Key)
                .ToList();

            if (duplicatedDocuments.Any())
            {
                Notifications.Error($"El archivo contiene identificaciones duplicadas: {string.Join(", ", duplicatedDocuments)}.");
                return;
            }

            var existingDocuments = _model.Passengers
                .Select(x => x.DocumentNumber?.Trim())
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            var alreadyAdded = passengers
                .Where(x => existingDocuments.Contains(x.DocumentNumber.Trim()))
                .Select(x => x.DocumentNumber)
                .Distinct()
                .ToList();

            if (alreadyAdded.Any())
            {
                Notifications.Error($"Ya existen pasajeros agregados con estas identificaciones: {string.Join(", ", alreadyAdded)}.");
                return;
            }

            _model.Passengers.AddRange(passengers);

            SyncPassengerCountersFromList();

            Notifications.Success($"Se cargaron {passengers.Count} pasajeros correctamente.");

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Notifications.Error($"No se pudo cargar el Excel: {ex.Message}");
        }
    }

    private static void ValidateExcelHeaders(IXLWorksheet worksheet)
    {
        var expectedHeaders = new[]
        {
            "Tipo de documento",
            "Número de documento",
            "Nombres y apellidos",
            "Nacionalidad",
            "Edad",
            "Tipo de pasajero",
            "Viaja ida (1/0)",
            "Viaja regreso (1/0)",
            "Fecha retorno"
        };

        for (var col = 1; col <= expectedHeaders.Length; col++)
        {
            var current = worksheet.Cell(1, col).GetString().Trim();

            if (!current.Equals(expectedHeaders[col - 1], StringComparison.OrdinalIgnoreCase))
            {
                throw new Exception($"La columna {col} debe ser '{expectedHeaders[col - 1]}'.");
            }
        }
    }

    private static string GetCellText(IXLWorksheet worksheet, int row, int column)
    {
        return worksheet.Cell(row, column).GetFormattedString().Trim();
    }

    private static bool IsEmptyRow(params string[] values)
    {
        return values.All(string.IsNullOrWhiteSpace);
    }

    private static bool TryParseDate(
        IXLWorksheet worksheet,
        int row,
        int column,
        string value,
        out DateTime? date)
    {
        date = null;

        var cell = worksheet.Cell(row, column);

        if (cell.DataType == XLDataType.DateTime)
        {
            date = cell.GetDateTime().Date;
            return true;
        }

        var formats = new[]
        {
            "dd/MM/yyyy",
            "yyyy-MM-dd",
            "d/M/yyyy",
            "dd-MM-yyyy"
        };

        if (DateTime.TryParseExact(
                value,
                formats,
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out var parsed))
        {
            date = parsed.Date;
            return true;
        }

        if (DateTime.TryParse(value, out parsed))
        {
            date = parsed.Date;
            return true;
        }

        return false;
    }

    private static bool TryParseBit(string value, out bool result)
    {
        result = false;

        value = value.Trim();

        if (value == "1" ||
            value.Equals("true", StringComparison.OrdinalIgnoreCase) ||
            value.Equals("sí", StringComparison.OrdinalIgnoreCase) ||
            value.Equals("si", StringComparison.OrdinalIgnoreCase))
        {
            result = true;
            return true;
        }

        if (value == "0" ||
            value.Equals("false", StringComparison.OrdinalIgnoreCase) ||
            value.Equals("no", StringComparison.OrdinalIgnoreCase))
        {
            result = false;
            return true;
        }

        return false;
    }

    private static bool TryMapPassengerType(string value, out string passengerType)
    {
        passengerType = string.Empty;

        var normalized = NormalizeText(value);

        passengerType = normalized switch
        {
            "adulto" => "Adult",
            "adult" => "Adult",
            "infante" => "Infant",
            "infant" => "Infant",
            "cortesia" => "Courtesy",
            "courtesy" => "Courtesy",
            _ => string.Empty
        };

        return !string.IsNullOrWhiteSpace(passengerType);
    }

    private string NormalizeNationality(string value)
    {
        return _nationalities.FirstOrDefault(x =>
            x.Equals(value.Trim(), StringComparison.OrdinalIgnoreCase)) ?? value.Trim();
    }

    private static string NormalizeText(string value)
    {
        value = value.Trim().ToLowerInvariant();

        return value
            .Replace("á", "a")
            .Replace("é", "e")
            .Replace("í", "i")
            .Replace("ó", "o")
            .Replace("ú", "u");
    }

    private async Task Save()
    {
        try
        {
            _saving = true;

            ValidatePassengersBeforeSave();
            ValidatePassengerQuantities();
            EnsureSelectedTripInModel();

            Guid reservationId;

            if (IsEditMode && ReservationId.HasValue)
            {
                await Service.UpdateAsync(ReservationId.Value, _model);
                reservationId = ReservationId.Value;
            }
            else
            {
                reservationId = await Service.CreateAsync(_model);
            }

            Notifications.Success(IsEditMode
                ? "Reserva actualizada correctamente."
                : "Reserva guardada correctamente.");

            if (IsEditMode)
                GoBack();
            else
                ResetForm();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private void ValidatePassengersBeforeSave()
    {
        if (!_model.OutboundDate.HasValue)
            throw new Exception("Debe seleccionar la fecha de ida.");

        if (_model.OutboundDate.Value.Date < DateTime.Today)
            throw new Exception("Solo puede registrar reservas desde el día actual en adelante.");
        var duplicates = _model.Passengers
            .Where(x => !x.IsCancelled)
            .Where(x => !x.IsGenericPassenger)
            .Where(x => !string.IsNullOrWhiteSpace(x.DocumentNumber))
            .GroupBy(x => x.DocumentNumber.Trim(), StringComparer.OrdinalIgnoreCase)
            .Where(x => x.Count() > 1)
            .Select(x => x.Key)
            .ToList();

        if (duplicates.Any())
            throw new Exception($"Existen pasajeros duplicados: {string.Join(", ", duplicates)}.");

        foreach (var passenger in _model.Passengers.Where(x => !x.IsCancelled))
        {
            if (passenger.IsGenericPassenger)
            {
                if (string.IsNullOrWhiteSpace(passenger.FullName))
                    passenger.FullName = "Pasajero genérico";

                if (string.IsNullOrWhiteSpace(passenger.DocumentNumber))
                    passenger.DocumentNumber = $"GEN-{Guid.NewGuid():N}"[..12];

                if (string.IsNullOrWhiteSpace(passenger.DocumentType))
                    passenger.DocumentType = "Generico";

                if (string.IsNullOrWhiteSpace(passenger.Nationality))
                    passenger.Nationality = "Ecuatoriana";

                if (passenger.Age is null)
                    passenger.Age = 18;

                if (string.IsNullOrWhiteSpace(passenger.PassengerType))
                    passenger.PassengerType = "Adult";

                continue;
            }
            if (string.IsNullOrWhiteSpace(passenger.DocumentNumber))
                throw new Exception("Todos los pasajeros deben tener identificación.");

            if (string.IsNullOrWhiteSpace(passenger.FullName))
                throw new Exception($"El pasajero {passenger.DocumentNumber} debe tener nombre completo.");

            if (string.IsNullOrWhiteSpace(passenger.Nationality))
                throw new Exception($"El pasajero {passenger.DocumentNumber} debe tener nacionalidad.");

            if (passenger.Age is null || passenger.Age < 0 || passenger.Age > 120)
                throw new Exception($"El pasajero {passenger.DocumentNumber} tiene una edad no válida.");

            if (passenger.Age <= 1 && passenger.PassengerType != "Infant")
                throw new Exception($"El pasajero {passenger.DocumentNumber} debe ser Infante por su edad.");

            if (passenger.Age > 1 && passenger.PassengerType == "Infant")
                throw new Exception($"El pasajero {passenger.DocumentNumber} no puede ser Infante si tiene más de 1 año.");

            if (passenger.Age > 1 &&
                passenger.PassengerType != "Adult" &&
                passenger.PassengerType != "Courtesy")
            {
                throw new Exception($"El pasajero {passenger.DocumentNumber} solo puede ser Adulto o Cortesía.");
            }

            if (passenger.Return)
            {
                if (!passenger.ReturnDate.HasValue)
                    throw new Exception($"El pasajero {passenger.DocumentNumber} debe tener fecha de retorno.");

                if (_model.OutboundDate.HasValue &&
                    passenger.ReturnDate.Value.Date < _model.OutboundDate.Value.Date)
                {
                    throw new Exception($"La fecha de retorno de {passenger.DocumentNumber} no puede ser menor a la fecha de ida.");
                }
            }
        }
    }

    private async Task OpenCustomerSearchDialogAsync(
    ReservationPassengerModel passenger,
    string? searchText)
    {
        var parameters = new DialogParameters
        {
            ["InitialSearch"] = searchText
        };

        var dialog = await Dialog.ShowAsync<CustomerSearchDialog>(
            "Buscar pasajero",
            parameters);

        var result = await dialog.Result;

        if (result.Canceled || result.Data is not ReservationPassengerModel selected)
            return;

        if (IsDuplicatedDocument(selected.DocumentNumber, passenger))
        {
            Notifications.Error($"Ya existe un pasajero con la identificación {selected.DocumentNumber}.");
            return;
        }

        passenger.CustomerId = selected.CustomerId;
        passenger.DocumentType = selected.DocumentType;
        passenger.DocumentNumber = selected.DocumentNumber;
        passenger.FullName = selected.FullName;
        passenger.Nationality = string.IsNullOrWhiteSpace(selected.Nationality)
            ? "Ecuatoriana"
            : selected.Nationality;
        passenger.Age = selected.Age;
        passenger.PassengerType = selected.PassengerType;
        passenger.Outbound = true;
        passenger.Return = selected.Return;
        passenger.ReturnDate = selected.Return ? _model.OutboundDate?.Date : null;
        passenger.IsNewCustomer = !selected.CustomerId.HasValue;
        passenger.CustomerChanged = passenger.IsNewCustomer;

        ApplyPassengerTypeByAge(passenger);
        SyncPassengerCountersFromList();
    }


    private void EnsureSelectedTripInModel()
    {
        if (_selectedTrip is null)
            throw new Exception("Debe seleccionar un viaje.");

        _model.OutboundRouteScheduleId = _selectedTrip.BoatRouteScheduleId;
        _model.OutboundDate = _selectedTrip.TravelDate.Date;

        foreach (var passenger in _model.Passengers.Where(x => !x.IsCancelled))
        {
            if (passenger.Return && !passenger.ReturnDate.HasValue)
                passenger.ReturnDate = _model.OutboundDate.Value.Date;
        }
    }

    private void ValidatePassengerQuantities()
    {
        var adultCount = _model.Passengers.Count(x => !x.IsCancelled && x.PassengerType == "Adult");
        var infantCount = _model.Passengers.Count(x => !x.IsCancelled && x.PassengerType == "Infant");
        var courtesyCount = _model.Passengers.Count(x => !x.IsCancelled && x.PassengerType == "Courtesy");

        if (adultCount != _adultCount)
            throw new Exception($"La cantidad de adultos no coincide. Indicados: {_adultCount}, cargados: {adultCount}.");

        if (infantCount != _infantCount)
            throw new Exception($"La cantidad de infantes no coincide. Indicados: {_infantCount}, cargados: {infantCount}.");

        if (courtesyCount != _courtesyCount)
            throw new Exception($"La cantidad de cortesías no coincide. Indicadas: {_courtesyCount}, cargadas: {courtesyCount}.");
    }

    private string GetAvailabilityClass(WeeklyAvailabilityItem item)
    {
        if (item.IsFull)
            return "ct-slot-button ct-slot-full";

        if (_selectedTrip?.BoatRouteScheduleId == item.BoatRouteScheduleId &&
            _selectedTrip.TravelDate.Date == item.TravelDate.Date)
            return "ct-slot-button ct-slot-selected";

        return "ct-slot-button ct-slot-available";
    }

    private string AvailabilityTitle
    {
        get
        {
            var boat = _boats.FirstOrDefault(x => x.Id == _boatId)?.Name;
            var route = _routes.FirstOrDefault(x => x.Id == _routeId);

            var routeName = route is null
                ? null
                : $"{route.Origin} - {route.Destination}";

            if (!string.IsNullOrWhiteSpace(boat) && !string.IsNullOrWhiteSpace(routeName))
                return $"{boat} · {routeName}";

            if (!string.IsNullOrWhiteSpace(boat))
                return boat;

            return string.Empty;
        }
    }

    private static DateTime GetStartOfWeek(DateTime date)
    {
        var diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.Date.AddDays(-diff);
    }

    private static string GetDayName(DateTime date)
    {
        return date.DayOfWeek switch
        {
            DayOfWeek.Monday => "Lun",
            DayOfWeek.Tuesday => "Mar",
            DayOfWeek.Wednesday => "Mié",
            DayOfWeek.Thursday => "Jue",
            DayOfWeek.Friday => "Vie",
            DayOfWeek.Saturday => "Sáb",
            DayOfWeek.Sunday => "Dom",
            _ => string.Empty
        };
    }

    private static bool TryMapDocumentType(string value, out string documentType)
    {
        documentType = string.Empty;

        var normalized = NormalizeText(value);

        documentType = normalized switch
        {
            "cedula" => "Cedula",
            "cedula de identidad" => "Cedula",
            "pasaporte" => "Pasaporte",
            _ => string.Empty
        };

        return !string.IsNullOrWhiteSpace(documentType);
    }

    private void SyncPassengerCountersFromList()
    {
        _adultCount = _model.Passengers.Count(x => !x.IsCancelled && x.PassengerType == "Adult");
        _infantCount = _model.Passengers.Count(x => !x.IsCancelled && x.PassengerType == "Infant");
        _courtesyCount = _model.Passengers.Count(x => !x.IsCancelled && x.PassengerType == "Courtesy");
    }

    private string GetPassengerRowClass(ReservationPassengerModel passenger, int rowNumber)
    {
        return passenger.PassengerType switch
        {
            "Adult" => "ct-passenger-adult",
            "Infant" => "ct-passenger-infant",
            "Courtesy" => "ct-passenger-courtesy",
            _ => string.Empty
        };
    }
    private async Task ReplacePassenger(ReservationPassengerModel current)
    {
        var dialog = await Dialog.ShowAsync<CustomerSearchDialog>("Reemplazar pasajero");
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not ReservationPassengerModel replacement)
            return;

        if (IsDuplicatedDocument(replacement.DocumentNumber, current))
        {
            Notifications.Error($"Ya existe un pasajero con la identificación {replacement.DocumentNumber}.");
            return;
        }

        current.CustomerId = replacement.CustomerId;
        current.DocumentType = replacement.DocumentType;
        current.DocumentNumber = replacement.DocumentNumber;
        current.FullName = replacement.FullName;
        current.Nationality = replacement.Nationality;
        current.Age = replacement.Age;
        current.PassengerType = replacement.PassengerType;
        current.IsNewCustomer = !replacement.CustomerId.HasValue;
        current.CustomerChanged = true;

        ApplyPassengerTypeByAge(current);

        if (IsEditMode && current.ReservationItemId.HasValue)
        {
            await Service.ReplacePassengerAsync(
                ReservationId!.Value,
                current.ReservationItemId.Value,
                current);

            Notifications.Success("Pasajero reemplazado.");
        }

        SyncPassengerCountersFromList();
    }

    private void ResetForm()
    {
        _model = new CreateReservationModel();

        _boatId = null;
        _routeId = null;
        _selectedTrip = null;

        _boats.Clear();
        _weekly.Clear();

        _adultCount = 0;
        _infantCount = 0;
        _courtesyCount = 0;

        StateHasChanged();
    }

