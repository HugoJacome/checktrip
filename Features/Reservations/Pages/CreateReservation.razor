@page "/reservations/create"

@using CheckAccess.Features.Reservations.Dialog
@using CheckTrip.Web.Features.Reservations.Models
@using CheckTrip.Web.Features.Reservations.Services
@using CheckTrip.Web.Infrastructure.Notifications
@using MudBlazor

@inject ReservationService Service
@inject BoatService BoatService
@inject AgencyService AgencyService
@inject SellerService SellerService
@inject IDialogService Dialog
@inject INotificationService Notifications
@inject NavigationManager Navigation

<MudStack Spacing="3">

    <MudText Typo="Typo.h5">Nueva Reserva</MudText>
    <MudText Typo="Typo.body2">
        Seleccione el viaje, cargue los pasajeros y confirme la reserva.
    </MudText>

    <MudPaper Class="pa-4">
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudTextField Label="ID"
                              Value="@("Generado automáticamente")"
                              Disabled="true" />
            </MudItem>

            <MudItem xs="12" md="3">
                <MudTextField Label="Código referencial"
                              @bind-Value="_model.ExternalReference" />
            </MudItem>

            <MudItem xs="12" md="3">
                <MudSelect T="Guid?" Label="Agencia" @bind-Value="_model.AgencyId" Clearable="true">
                    @foreach (var a in _agencies)
                    {
                        <MudSelectItem T="Guid?" Value="@a.Id">@a.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="3">
                <MudSelect T="Guid?" Label="Vendedor" @bind-Value="_model.SellerId" Clearable="true">
                    @foreach (var s in _sellers)
                    {
                        <MudSelectItem T="Guid?" Value="@s.Id">@s.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="3">
                <MudSelect T="Guid?" Label="Lancha" Value="_boatId" ValueChanged="OnBoatChanged" Clearable="true">
                    @foreach (var b in _boats)
                    {
                        <MudSelectItem T="Guid?" Value="@b.Id">@b.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="3">
                <MudDatePicker Label="Semana" Date="_weekStart" DateChanged="OnWeekChanged" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudNumericField T="int" Label="Adultos" @bind-Value="_adultCount" Min="0" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudNumericField T="int" Label="Infantes" @bind-Value="_infantCount" Min="0" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudNumericField T="int" Label="Cortesías" @bind-Value="_courtesyCount" Min="0" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6">Disponibilidad semanal</MudText>

            <MudStack Row="true">
                <MudButton Variant="Variant.Outlined" OnClick="PreviousWeek">Semana anterior</MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="NextWeek">Semana siguiente</MudButton>
            </MudStack>
        </MudStack>

        <MudGrid Class="mt-3">
            @foreach (var day in WeekDays)
            {
                <MudItem xs="12" md="@(12 / 7)">
                    <MudPaper Class="pa-2 ct-day-card">
                        <MudText Typo="Typo.subtitle2">@day.ToString("ddd dd/MM")</MudText>

                        @foreach (var item in _weekly.Where(x => x.TravelDate.Date == day.Date))
                        {
                            <MudPaper Class="@GetAvailabilityClass(item)"
                                      @onclick="@(() => SelectTrip(item))">
                                <MudText Typo="Typo.body2">@item.Schedule</MudText>
                                <MudText Typo="Typo.caption">@item.Route</MudText>
                                <MudText Typo="Typo.caption">@item.Available cupos</MudText>
                            </MudPaper>
                        }
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4">
        <MudText Typo="Typo.subtitle1">Viaje seleccionado</MudText>

        @if (_selectedTrip is null)
        {
            <MudAlert Severity="Severity.Info">
                Seleccione un día y horario disponible.
            </MudAlert>
        }
        else
        {
            <MudText>
                @_selectedTrip.TravelDate.ToString("dd/MM/yyyy") -
                @_selectedTrip.Schedule -
                @_selectedTrip.Route -
                @_selectedTrip.Boat
            </MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6">Listado de pasajeros</MudText>

            <MudStack Row="true">
                <MudButton Variant="Variant.Outlined" OnClick="AddPassengerDialog">
                    Buscar / Registrar
                </MudButton>

                <MudButton Variant="Variant.Outlined" Color="Color.Info">
                    Cargar Excel
                </MudButton>
            </MudStack>
        </MudStack>

        <MudTable Items="_model.Passengers" Dense="true" Hover="true" Bordered="true" Class="mt-3">
            <HeaderContent>
                <MudTh>N°</MudTh>
                <MudTh>Identificación</MudTh>
                <MudTh>Nombre y apellido</MudTh>
                <MudTh>Nacionalidad</MudTh>
                <MudTh>Fecha nacimiento</MudTh>
                <MudTh>Tipo</MudTh>
                <MudTh>Ida</MudTh>
                <MudTh>Regreso</MudTh>
                <MudTh></MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd>@(_model.Passengers.IndexOf(context) + 1)</MudTd>

                <MudTd>
                    <MudTextField T="string" @bind-Value="context.DocumentNumber" Dense="true" />
                </MudTd>

                <MudTd>
                    <MudTextField T="string" @bind-Value="context.FullName" Dense="true" />
                </MudTd>

                <MudTd>
                    <MudTextField T="string" @bind-Value="context.Nationality" Dense="true" />
                </MudTd>

                <MudTd>
                    <MudDatePicker @bind-Date="context.BirthDate" Dense="true" />
                </MudTd>

                <MudTd>
                    <MudSelect T="string" @bind-Value="context.PassengerType" Dense="true">
                        <MudSelectItem Value="@("Adult")">Adulto</MudSelectItem>
                        <MudSelectItem Value="@("Infant")">Infante</MudSelectItem>
                        <MudSelectItem Value="@("Courtesy")">Cortesía</MudSelectItem>
                    </MudSelect>
                </MudTd>

                <MudTd>
                    <MudCheckBox T="bool" @bind-Checked="context.Outbound" />
                </MudTd>

                <MudTd>
                    <MudCheckBox T="bool" @bind-Checked="context.Return" />
                </MudTd>

                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   OnClick="@(() => RemovePassenger(context))" />
                </MudTd>
            </RowTemplate>

            <NoRecordsContent>
                <MudText>No existen pasajeros agregados.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>

    <MudStack Row="true" Justify="Justify.FlexEnd">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@IsSaveDisabled"
                   OnClick="Save">
            Guardar Reserva
        </MudButton>
    </MudStack>
</MudStack>

@code {
    private CreateReservationModel _model = new();

    private List<BoatListItem> _boats = [];
    private List<AgencyListItem> _agencies = [];
    private List<SellerListItem> _sellers = [];
    private List<WeeklyAvailabilityItem> _weekly = [];

    private Guid? _boatId;
    private DateTime? _weekStart = DateTime.Today;

    private WeeklyAvailabilityItem? _selectedTrip;

    private int _adultCount = 1;
    private int _infantCount;
    private int _courtesyCount;

    private bool _saving;

    private bool IsSaveDisabled =>
        _saving ||
        _selectedTrip is null ||
        !_model.Passengers.Any();

    private IEnumerable<DateTime> WeekDays =>
        Enumerable.Range(0, 7).Select(x => GetStartOfWeek(_weekStart ?? DateTime.Today).AddDays(x));

    protected override async Task OnInitializedAsync()
    {
        _boats = await BoatService.GetAllAsync();
        _agencies = await AgencyService.GetAllAsync();
        _sellers = await SellerService.GetAllAsync();

        _weekStart = GetStartOfWeek(DateTime.Today);

        await LoadWeeklyAvailability();
    }

    private async Task OnBoatChanged(Guid? value)
    {
        _boatId = value;
        _selectedTrip = null;
        await LoadWeeklyAvailability();
    }

    private async Task OnWeekChanged(DateTime? value)
    {
        _weekStart = GetStartOfWeek(value ?? DateTime.Today);
        _selectedTrip = null;
        await LoadWeeklyAvailability();
    }

    private async Task PreviousWeek()
    {
        _weekStart = GetStartOfWeek((_weekStart ?? DateTime.Today).AddDays(-7));
        _selectedTrip = null;
        await LoadWeeklyAvailability();
    }

    private async Task NextWeek()
    {
        _weekStart = GetStartOfWeek((_weekStart ?? DateTime.Today).AddDays(7));
        _selectedTrip = null;
        await LoadWeeklyAvailability();
    }

    private async Task LoadWeeklyAvailability()
    {
        _weekly = await Service.GetWeeklyAvailabilityAsync(
            GetStartOfWeek(_weekStart ?? DateTime.Today),
            _boatId);
    }

    private void SelectTrip(WeeklyAvailabilityItem item)
    {
        if (item.IsFull)
        {
            Notifications.Error("Este viaje no tiene cupos disponibles.");
            return;
        }

        _selectedTrip = item;

        _model.OutboundRouteScheduleId = item.BoatRouteScheduleId;
        _model.OutboundDate = item.TravelDate;

        foreach (var passenger in _model.Passengers)
        {
            passenger.Outbound = true;
            passenger.Return = false;
        }
    }

    private async Task AddPassengerDialog()
    {
        var dialog = await Dialog.ShowAsync<CustomerSearchDialog>("Pasajero");
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is ReservationPassengerModel passenger)
        {
            _model.Passengers.Add(passenger);
        }
    }

    private void RemovePassenger(ReservationPassengerModel passenger)
    {
        _model.Passengers.Remove(passenger);
    }

    private async Task Save()
    {
        try
        {
            _saving = true;

            ValidatePassengerQuantities();

            var id = await Service.CreateAsync(_model);

            Notifications.Success("Reserva creada correctamente.");

            Navigation.NavigateTo("/reservations/monitor");
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private void ValidatePassengerQuantities()
    {
        var adultCount = _model.Passengers.Count(x => x.PassengerType == "Adult");
        var infantCount = _model.Passengers.Count(x => x.PassengerType == "Infant");
        var courtesyCount = _model.Passengers.Count(x => x.PassengerType == "Courtesy");

        if (adultCount != _adultCount)
            throw new Exception($"Debe ingresar {_adultCount} pasajeros adultos.");

        if (infantCount != _infantCount)
            throw new Exception($"Debe ingresar {_infantCount} pasajeros infantes.");

        if (courtesyCount != _courtesyCount)
            throw new Exception($"Debe ingresar {_courtesyCount} cortesías.");
    }

    private string GetAvailabilityClass(WeeklyAvailabilityItem item)
    {
        if (item.IsFull)
            return "pa-2 mt-2 ct-slot ct-slot-full";

        if (_selectedTrip?.BoatRouteScheduleId == item.BoatRouteScheduleId &&
            _selectedTrip.TravelDate.Date == item.TravelDate.Date)
            return "pa-2 mt-2 ct-slot ct-slot-selected";

        return "pa-2 mt-2 ct-slot ct-slot-available";
    }

    private static DateTime GetStartOfWeek(DateTime date)
    {
        var diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.Date.AddDays(-diff);
    }
}