@page "/reservations/monitor"

@using CheckAccess.Features.Security
@using CheckAccess.Features.Tickets.Dialog
@using CheckTrip.Web.Features.Reservations.Models
@using CheckTrip.Web.Features.Reservations.Services
@using CheckTrip.Web.Features.Tickets.Models
@using CheckTrip.Web.Features.Tickets.Services
@using CheckTrip.Web.Infrastructure.Notifications
@using MudBlazor

@inject NavigationManager Navigation
@inject BoatService BoatService
@inject TicketService TicketService
@inject BoatDailyTripService BoatDailyTripService
@inject IDialogService Dialog
@inject INotificationService Notifications

<RequirePermission ResourceCode="reservations.monitor">
    <MudStack Spacing="3">

        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h5">Monitor de Viaje</MudText>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@_isLocked"
                       OnClick="@(() => Navigation.NavigateTo("/reservations/create"))">
                Nueva reserva
            </MudButton>
        </MudStack>

        <MudPaper Class="pa-4">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudDatePicker Label="Fecha del viaje"
                                   @bind-Date="_tripDate"
                                   DateFormat="yyyy-MM-dd" />
                </MudItem>

                <MudItem xs="12" md="5">
                    <MudSelect T="Guid?"
                               Label="Bote"
                               @bind-Value="_boatId"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        @foreach (var boat in _boats)
                        {
                            <MudSelectItem Value="@((Guid?)boat.Id)">
                                @boat.Name
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="3" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="LoadTrip">
                        Consultar
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_tripLoaded)
        {
            <MudPaper Class="pa-4">
                <MudStack Row="true"
                          AlignItems="AlignItems.Center"
                          Justify="Justify.SpaceBetween">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h6">@_selectedBoatName</MudText>
                        <MudText Typo="Typo.body2">
                            Fecha: @_tripDate?.ToString("yyyy-MM-dd")
                        </MudText>

                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@GetTripStatusColor(_tripStatus)">
                            @GetTripStatusText(_tripStatus)
                        </MudChip>

                        @if (!string.IsNullOrWhiteSpace(_documentNumber))
                        {
                            <MudText Typo="Typo.body2">
                                Documento: @_documentNumber
                            </MudText>
                        }
                    </MudStack>

                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@_isLocked"
                                   StartIcon="@Icons.Material.Filled.ConfirmationNumber"
                                   OnClick="GenerateTickets">
                            Generar boletos
                        </MudButton>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   Disabled="@_isLocked"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenGenericTicket">
                            Boleto genérico
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Disabled="@_isLocked"
                                   StartIcon="@Icons.Material.Filled.Description"
                                   OnClick="GenerateTripDocument">
                            Generar documento
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>

            @if (_isLocked)
            {
                <MudAlert Severity="Severity.Warning">
                    Este viaje ya tiene documento generado o está cerrado. No se pueden agregar más reservas ni boletos.
                </MudAlert>
            }

            <MudTable Items="_tickets" Dense="true" Hover="true" Bordered="true" Loading="_loading">
                <HeaderContent>
                    <MudTh>Boleto</MudTh>
                    <MudTh>Documento</MudTh>
                    <MudTh>Pasajero</MudTh>
                    <MudTh>Viaje</MudTh>
                    <MudTh>Tipo</MudTh>
                    <MudTh>Impreso</MudTh>
                    <MudTh>Reimp.</MudTh>
                    <MudTh>Acciones</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd>@context.TicketNumber</MudTd>
                    <MudTd>@context.DocumentNumber</MudTd>
                    <MudTd>@context.PassengerName</MudTd>
                    <MudTd>@context.TripType</MudTd>
                    <MudTd>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.IsGeneric ? Color.Warning : Color.Info)">
                            @(context.IsGeneric ? "Genérico" : "Reserva")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.IsPrinted ? Color.Success : Color.Warning)">
                            @(context.IsPrinted ? "Sí" : "No")
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.ReprintCount</MudTd>
                    <MudTd>
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Text"
                                   Color="Color.Primary"
                                   OnClick="@(() => MarkPrinted(context.Id))">
                            @(context.IsPrinted ? "Reimprimir" : "Imprimir")
                        </MudButton>
                    </MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <MudText>No existen boletos para este bote y fecha.</MudText>
                </NoRecordsContent>
            </MudTable>
        }
    </MudStack>
</RequirePermission>

@code {
    private List<BoatListItem> _boats = [];
    private List<TicketListItem> _tickets = [];
    private DateTime? _tripDate = DateTime.UtcNow.Date;
    private Guid? _boatId;

    private bool _loading;
    private bool _tripLoaded;
    private bool _isLocked;

    private string _tripStatus = BoatDailyTripStatus.Open;
    private string? _documentNumber;
    private string _selectedBoatName = "";

    protected override async Task OnInitializedAsync()
    {
        _boats = await BoatService.GetAllAsync();
    }
    private static DateTime ToUtcDate(DateTime date)
    {
        return DateTime.SpecifyKind(date.Date, DateTimeKind.Utc);
    }
    private async Task LoadTrip()
    {
        if (!_boatId.HasValue)
        {
            Notifications.Warning("Seleccione un bote.");
            return;
        }

        if (!_tripDate.HasValue)
        {
            Notifications.Warning("Seleccione la fecha del viaje.");
            return;
        }

        _loading = true;

        try
        {
            var tripDateUtc = ToUtcDate(_tripDate.Value);

            var trip = await BoatDailyTripService.GetOrCreateAsync(_boatId.Value, tripDateUtc);

            _tripStatus = trip.Status;
            _isLocked = trip.IsLocked;
            _documentNumber = trip.DocumentNumber;
            _selectedBoatName = _boats.FirstOrDefault(x => x.Id == _boatId.Value)?.Name ?? "";

            _tickets = await TicketService.GetMonitorByBoatAndDateAsync(_boatId.Value, tripDateUtc);

            _tripLoaded = true;
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task GenerateTickets()
    {
        if (!_boatId.HasValue || !_tripDate.HasValue)
            return;

        if (_isLocked)
        {
            Notifications.Warning("El viaje ya está bloqueado.");
            return;
        }

        try
        {
            await TicketService.GenerateForBoatAndDateAsync(_boatId.Value, _tripDate.Value);
            Notifications.Success("Boletos generados correctamente.");
            await LoadTrip();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
    }

    private async Task OpenGenericTicket()
    {
        if (!_boatId.HasValue || !_tripDate.HasValue)
            return;

        if (_isLocked)
        {
            Notifications.Warning("El viaje ya está bloqueado.");
            return;
        }

        var parameters = new DialogParameters
        {
            ["BoatId"] = _boatId.Value,
            ["TripDate"] = _tripDate.Value
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await Dialog.ShowAsync<GenericTicketDialog>("Boleto genérico", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadTrip();
    }

    private async Task GenerateTripDocument()
    {
        if (!_boatId.HasValue || !_tripDate.HasValue)
            return;

        try
        {
            await TicketService.GenerateForBoatAndDateAsync(_boatId.Value, _tripDate.Value);
            await BoatDailyTripService.GenerateDocumentAsync(_boatId.Value, _tripDate.Value);

            Notifications.Success("Documento del viaje generado. El viaje quedó bloqueado.");
            await LoadTrip();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
    }

    private async Task MarkPrinted(Guid ticketId)
    {
        try
        {
            await TicketService.MarkPrintedAsync(ticketId);
            Notifications.Success("Boleto actualizado correctamente.");
            await LoadTrip();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
    }

    private static Color GetTripStatusColor(string status)
    {
        return status switch
        {
            BoatDailyTripStatus.Open => Color.Info,
            BoatDailyTripStatus.DocumentGenerated => Color.Warning,
            BoatDailyTripStatus.Closed => Color.Success,
            _ => Color.Default
        };
    }

    private static string GetTripStatusText(string status)
    {
        return status switch
        {
            BoatDailyTripStatus.Open => "Abierto",
            BoatDailyTripStatus.DocumentGenerated => "Documento generado",
            BoatDailyTripStatus.Closed => "Cerrado",
            _ => status
        };
    }
}