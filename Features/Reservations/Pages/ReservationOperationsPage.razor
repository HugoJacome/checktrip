@page "/reservations/operations"

@using CheckAccess.Features.Reservations.Dialog
@using CheckAccess.Features.Security
@using CheckTrip.Web.Features.Reservations.Models.Operations
@using CheckTrip.Web.Features.Reservations.Services
@using CheckTrip.Web.Features.Tickets.Services
@using CheckTrip.Web.Infrastructure.Notifications
@using MudBlazor

@inject BoatDailyTripService BoatDailyTripService
@inject ReservationService ReservationService
@inject IDialogService DialogService
@inject INotificationService Notifications
@inject NavigationManager Navigation

<RequirePermission ResourceCode="reservations.monitor">
    <MudStack Spacing="3">

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h5">Operaciones de viajes</MudText>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadAsync">
                Recargar
            </MudButton>
        </MudStack>

        <MudPaper Class="pa-4">
            <MudGrid>
                <MudItem xs="12" md="2">
                    <MudDatePicker Label="Desde" @bind-Date="_filter.DateFrom" />
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudDatePicker Label="Hasta" @bind-Date="_filter.DateTo" />
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudSelect T="Guid?" Label="Bote" @bind-Value="_filter.BoatId" Clearable="true">
                        @foreach (var boat in _boats)
                        {
                            <MudSelectItem T="Guid?" Value="@boat.Id">@boat.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudSelect T="Guid?" Label="Ruta" @bind-Value="_filter.RouteId" Clearable="true">
                        @foreach (var route in _routes)
                        {
                            <MudSelectItem T="Guid?" Value="@route.Id">@route.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudSelect T="Guid?" Label="Agencia" @bind-Value="_filter.AgencyId" Clearable="true">
                        @foreach (var agency in _agencies)
                        {
                            <MudSelectItem T="Guid?" Value="@agency.Id">@agency.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudSelect T="Guid?" Label="Vendedor" @bind-Value="_filter.SellerId" Clearable="true">
                        @foreach (var seller in _sellers)
                        {
                            <MudSelectItem T="Guid?" Value="@seller.Id">@seller.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudSelect T="string" Label="Estado viaje" @bind-Value="_filter.Status" Clearable="true">
                        <MudSelectItem Value="@("Open")">Abierto</MudSelectItem>
                        <MudSelectItem Value="@("DocumentGenerated")">Documento generado</MudSelectItem>
                        <MudSelectItem Value="@("Closed")">Cerrado</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudSelect T="bool?" Label="Documento" @bind-Value="_filter.DocumentGenerated" Clearable="true">
                        <MudSelectItem T="bool?" Value="true">Generado</MudSelectItem>
                        <MudSelectItem T="bool?" Value="false">No generado</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudStack Row="true" Spacing="2" Class="mt-4">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   OnClick="LoadAsync">
                            Buscar
                        </MudButton>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.Clear"
                                   OnClick="ClearFilters">
                            Limpiar
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Assessment"
                                   OnClick="OpenReportDialog">
                            Reporte
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            @TripsTable()
        }

        @if (_selectedTrip is not null)
        {
            <MudPaper Class="pa-4">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.h6">
                            Pasajeros - @_selectedTrip.Boat / @_selectedTrip.Route / @_selectedTrip.Schedule / @_selectedTrip.TripDate.ToString("yyyy-MM-dd")
                        </MudText>

                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="ClearSelectedTrip">
                            Cerrar
                        </MudButton>
                    </MudStack>

                    @PassengersTable()
                </MudStack>
            </MudPaper>
        }

    </MudStack>
</RequirePermission>

@code {
    private bool _loading;

    private BoatDailyTripOperationsFilter _filter = new()
    {
        DateFrom = DateTime.Today,
        DateTo = DateTime.Today
    };

    private BoatDailyTripOperationItem? _selectedTrip;

    private List<BoatDailyTripOperationItem> _trips = [];
    private List<BoatDailyTripPassengerOperationItem> _passengers = [];

    private List<CatalogItem> _boats = [];
    private List<CatalogItem> _routes = [];
    private List<CatalogItem> _agencies = [];
    private List<CatalogItem> _sellers = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalogsAsync();
        await LoadAsync();
    }

    private async Task LoadCatalogsAsync()
    {
        _boats = await ReservationService.GetOperationBoatsAsync();
        _agencies = await ReservationService.GetOperationAgenciesAsync();
        _sellers = await ReservationService.GetOperationSellersAsync();

        var routeSchedules = await ReservationService.GetOperationRouteSchedulesAsync();

        _routes = routeSchedules
            .GroupBy(x => x.RouteId)
            .Select(x => new CatalogItem
            {
                Id = x.Key,
                Name = x.First().Route
            })
            .OrderBy(x => x.Name)
            .ToList();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _selectedTrip = null;
            _passengers = [];

            _trips = await BoatDailyTripService.GetOperationsAsync(_filter);
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ClearFilters()
    {
        _filter = new BoatDailyTripOperationsFilter
        {
            DateFrom = DateTime.Today,
            DateTo = DateTime.Today
        };

        await LoadAsync();
    }

    private async Task SelectTripAsync(BoatDailyTripOperationItem trip)
    {
        try
        {
            _selectedTrip = trip;
            _passengers = await BoatDailyTripService.GetPassengersAsync(trip.Id);
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
    }

    private void ClearSelectedTrip()
    {
        _selectedTrip = null;
        _passengers = [];
    }

    private async Task OpenChangeBoatDialog(Guid boatDailyTripId)
    {
        var parameters = new DialogParameters
        {
            ["BoatDailyTripId"] = boatDailyTripId
        };

        var dialog = await DialogService.ShowAsync<ChangeBoatDailyTripDialog>(
            "Cambiar embarcación",
            parameters);

        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadAsync();
    }

    private async Task OpenCrewDialog(Guid boatDailyTripId)
    {
        var parameters = new DialogParameters
        {
            ["BoatDailyTripId"] = boatDailyTripId
        };

        var dialog = await DialogService.ShowAsync<BoatDailyTripCrewDialog>(
            "Tripulación",
            parameters);

        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadAsync();
    }

    private async Task OpenCommentDialog(Guid boatDailyTripId)
    {
        var parameters = new DialogParameters
        {
            ["BoatDailyTripId"] = boatDailyTripId
        };

        var dialog = await DialogService.ShowAsync<BoatDailyTripCommentDialog>(
            "Comentario operativo",
            parameters);

        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadAsync();
    }

    private async Task GenerateDocumentAsync(BoatDailyTripOperationItem trip)
    {
        try
        {
            await BoatDailyTripService.GenerateDocumentAsync(trip.BoatRouteScheduleId, trip.TripDate.ToDateTime(TimeOnly.MinValue));
            Notifications.Success("Documento generado.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
    }

    private async Task CloseTripAsync(Guid boatDailyTripId)
    {
        try
        {
            await BoatDailyTripService.CloseByIdAsync(boatDailyTripId);
            Notifications.Success("Viaje cerrado.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message);
        }
    }

    private void EditReservation(Guid reservationId)
    {
        Navigation.NavigateTo($"/reservations/create/{reservationId}?returnUrl={Uri.EscapeDataString("/reservations/operations")}");
    }

    private RenderFragment TripsTable() => @<MudTable Items="_trips"
                                                      Dense="true"
                                                      Hover="true"
                                                      Bordered="true"
                                                      Elevation="0">
        <HeaderContent>
            <MudTh>Fecha</MudTh>
            <MudTh>Bote</MudTh>
            <MudTh>Ruta</MudTh>
            <MudTh>Horario</MudTh>
            <MudTh>Capitán</MudTh>
            <MudTh>Marineros</MudTh>
            <MudTh>Pax</MudTh>
            <MudTh>Capacidad</MudTh>
            <MudTh>Estado</MudTh>
            <MudTh>Documento</MudTh>
            <MudTh>Comentario</MudTh>
            <MudTh>Acciones</MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd>@context.TripDate.ToString("yyyy-MM-dd")</MudTd>
            <MudTd>@context.Boat</MudTd>
            <MudTd>@context.Route</MudTd>
            <MudTd>@context.Schedule</MudTd>
            <MudTd>@context.CaptainName</MudTd>
            <MudTd>@context.Sailors</MudTd>
            <MudTd>@context.PassengerCount</MudTd>
            <MudTd>@context.TotalCapacity</MudTd>
            <MudTd>
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@GetTripStatusColor(context.Status)">
                    @GetTripStatusText(context.Status)
                </MudChip>
            </MudTd>
            <MudTd>
                @if (context.HasDocument)
                            {
                <MudStack Spacing="0">
                    <MudText Typo="Typo.body2">@context.DocumentNumber</MudText>
                    <MudText Typo="Typo.caption">@context.DocumentGeneratedAt?.ToString("yyyy-MM-dd HH:mm")</MudText>
                </MudStack>
                            }
                            else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Pendiente</MudChip>
                }
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.body2">@context.LastComment</MudText>
            </MudTd>
            <MudTd>
                <MudMenu Dense="true" Icon="@Icons.Material.Filled.MoreVert">
                    <MudMenuItem OnClick="@(() => SelectTripAsync(context))">
                        Ver pasajeros
                    </MudMenuItem>

                    <MudMenuItem OnClick="@(() => OpenCrewDialog(context.Id))"
                                 Disabled="@context.IsLocked">
                        Editar tripulación
                    </MudMenuItem>

                    <MudMenuItem OnClick="@(() => OpenChangeBoatDialog(context.Id))"
                                 Disabled="@context.IsLocked">
                        Cambiar embarcación
                    </MudMenuItem>

                    <MudMenuItem OnClick="@(() => GenerateDocumentAsync(context))"
                                 Disabled="@context.IsLocked">
                        Generar documento
                    </MudMenuItem>

                    <MudMenuItem OnClick="@(() => CloseTripAsync(context.Id))"
                                 Disabled="@(context.Status != "DocumentGenerated")">
                        Cerrar viaje
                    </MudMenuItem>

                    <MudMenuItem OnClick="@(() => OpenCommentDialog(context.Id))">
                        Agregar comentario
                    </MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText>No existen viajes con los filtros seleccionados.</MudText>
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>;

    private RenderFragment PassengersTable() => @<MudTable Items="_passengers"
                                                           Dense="true"
                                                           Hover="true"
                                                           Bordered="true"
                                                           Elevation="0">
        <HeaderContent>
            <MudTh>Reserva</MudTh>
            <MudTh>Agencia</MudTh>
            <MudTh>Vendedor</MudTh>
            <MudTh>Pasajero</MudTh>
            <MudTh>Documento</MudTh>
            <MudTh>Tipo</MudTh>
            <MudTh>Ida</MudTh>
            <MudTh>Retorno</MudTh>
            <MudTh>Pago</MudTh>
            <MudTh>Estado reserva</MudTh>
            <MudTh>Acciones</MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd>@context.ReservationCode</MudTd>
            <MudTd>@context.Agency</MudTd>
            <MudTd>@context.Seller</MudTd>
            <MudTd>@context.FullName</MudTd>
            <MudTd>@context.DocumentNumber</MudTd>
            <MudTd>@context.PassengerType</MudTd>

            <MudTd>
                @if (context.HasOutbound)
                {
                    <MudText Typo="Typo.body2">@context.OutboundTravelDate?.ToString("yyyy-MM-dd")</MudText>
                    <MudText Typo="Typo.caption">@context.OutboundBoat</MudText>
                    <br />
                    <MudText Typo="Typo.caption">@context.OutboundRoute / @context.OutboundSchedule</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption">-</MudText>
                }
            </MudTd>

            <MudTd>
                @if (context.HasReturn)
                {
                    <MudText Typo="Typo.body2">@context.ReturnTravelDate?.ToString("yyyy-MM-dd")</MudText>
                    <MudText Typo="Typo.caption">@context.ReturnBoat</MudText>
                    <br />
                    <MudText Typo="Typo.caption">@context.ReturnRoute / @context.ReturnSchedule</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption">-</MudText>
                }
            </MudTd>

            <MudTd>@context.PaymentStatus</MudTd>
            <MudTd>@context.ReservationStatus</MudTd>

            <MudTd>
                <MudButton Variant="Variant.Text"
                           Size="Size.Small"
                           Color="Color.Primary"
                           OnClick="@(() => EditReservation(context.ReservationId))">
                    Ver reserva
                </MudButton>
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText>No existen pasajeros para este viaje.</MudText>
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>;

    private static Color GetTripStatusColor(string status)
    {
        return status switch
        {
            "Open" => Color.Info,
            "DocumentGenerated" => Color.Warning,
            "Closed" => Color.Success,
            _ => Color.Default
        };
    }

    private static string GetTripStatusText(string status)
    {
        return status switch
        {
            "Open" => "Abierto",
            "DocumentGenerated" => "Documento generado",
            "Closed" => "Cerrado",
            _ => status
        };
    }
    private async Task OpenReportDialog()
    {
        var parameters = new DialogParameters
        {
            ["Filter"] = _filter
        };

        await DialogService.ShowAsync<OperationsReportDialog>(
            "Reporte de operaciones",
            parameters,
            new DialogOptions
            {
                MaxWidth = MaxWidth.ExtraLarge,
                FullWidth = true,
                CloseButton = true
            });
    }
}