@using CheckTrip.Web.Features.Reservations.Models
@using CheckTrip.Web.Features.Reservations.Services
@using MudBlazor

@inject ReservationService Service
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_detail is not null)
        {
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">
                    Reserva @_detail.ReservationCode
                </MudText>

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudText><b>Estado:</b> @_detail.Status</MudText>
                        <MudText><b>Pago:</b> @_detail.PaymentStatus</MudText>
                        <MudText><b>Agencia:</b> @_detail.Agency</MudText>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudText><b>Vendedor:</b> @_detail.Seller</MudText>
                        <MudText><b>Fecha:</b> @_detail.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
                    </MudItem>
                </MudGrid>

                <MudDivider />

                <MudText Typo="Typo.subtitle1">Pasajeros</MudText>

                <MudTable Items="_detail.Passengers" Dense="true" Bordered="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Documento</MudTh>
                        <MudTh>Nombre</MudTh>
                        <MudTh>Edad</MudTh>
                        <MudTh>Tipo</MudTh>
                        <MudTh>Viaje</MudTh>
                        <MudTh>Ida</MudTh>
                        <MudTh>Retorno</MudTh>
                        <MudTh>Estado</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd>@context.DocumentNumber</MudTd>
                        <MudTd>@context.FullName</MudTd>
                        <MudTd>@context.Age</MudTd>
                        <MudTd>@context.PassengerType</MudTd>
                        <MudTd>@context.TripType</MudTd>
                        <MudTd>
                            @if (context.OutboundTrip is not null)
                            {
                                <MudText Typo="Typo.body2">@context.OutboundTrip</MudText>
                                <MudText Typo="Typo.caption">@context.OutboundDate</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            @if (context.ReturnTrip is not null)
                            {
                                <MudText Typo="Typo.body2">@context.ReturnTrip</MudText>
                                <MudText Typo="Typo.caption">@context.ReturnDate</MudText>
                            }
                        </MudTd>
                        <MudTd>@context.Status</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudStack>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Close">Cerrar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid ReservationId { get; set; }

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private bool _loading = true;
    private ReservationDetailModel? _detail;

    protected override async Task OnInitializedAsync()
    {
        _detail = await Service.GetDetailAsync(ReservationId);
        _loading = false;
    }

    private void Close()
    {
        MudDialog.Close();
    }
}