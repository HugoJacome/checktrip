@using CheckTrip.Web.Features.Catalogs.Schedules.Services
@using MudBlazor

@inject BoatRouteScheduleService Service
@inject BoatService BoatService
@inject RouteService RouteService
@inject ScheduleService ScheduleService

<MudDialog>
    <DialogContent>

        <MudSelect T="Guid" Label="Bote" @bind-Value="_model.BoatId">
            @foreach (var b in _boats)
            {
                <MudSelectItem Value="@b.Id">@b.Name</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="Guid" Label="Ruta" @bind-Value="_model.RouteId">
            @foreach (var r in _routes)
            {
                <MudSelectItem Value="@r.Id">@($"{r.Origin} - {r.Destination}")</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="Guid" Label="Horario" @bind-Value="_model.ScheduleId">
            @foreach (var s in _schedules)
            {
                <MudSelectItem Value="@s.Id">@s.Name</MudSelectItem>
            }
        </MudSelect>

        <MudNumericField T="decimal" Label="Precio" @bind-Value="_model.Price" />

        <MudTextField T="string" Label="Días (ej: L-M-M-J-V)" @bind-Value="_model.Days" />

        <MudTextField T="string" Label="Color" @bind-Value="_model.Color" />

    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Save" Color="Color.Primary">Guardar</MudButton>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Guid? Id { get; set; }

    private BoatRouteScheduleEditModel _model = new();

    private List<BoatListItem> _boats = new();
    private List<RouteListItem> _routes = new();
    private List<ScheduleListItem> _schedules = new();

    protected override async Task OnInitializedAsync()
    {
        _boats = await BoatService.GetAllAsync();
        _routes = await RouteService.GetAllAsync();
        _schedules = await ScheduleService.GetAllAsync();

        if (Id != null)
        {
            var data = await Service.GetAsync(Id.Value);
            if (data != null)
                _model = data;
        }
    }

    private async Task Save()
    {
        await Service.SaveAsync(_model);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}