@using MudBlazor

@inject AgencyService Service
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.subtitle1">
                Datos de la agencia
            </MudText>

            <MudForm @ref="_form">
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="8">
                        <MudTextField T="string"
                                      Label="Nombre"
                                      @bind-Value="_model.Name"
                                      Required="true"
                                      RequiredError="El nombre es obligatorio."
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudTextField T="string"
                                      Label="RUC"
                                      @bind-Value="_model.Ruc"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Tipo"
                                      @bind-Value="_model.Type"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Teléfono"
                                      @bind-Value="_model.Phone"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField T="string"
                                      Label="Dirección"
                                      @bind-Value="_model.Address"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Email"
                                      @bind-Value="_model.Email"
                                      InputType="InputType.Email"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Persona de contacto"
                                      @bind-Value="_model.ContactPerson"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Teléfono contacto"
                                      @bind-Value="_model.ContactPhone"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudCheckBox T="bool"
                                     Label="Activo"
                                     @bind-Value="_model.IsActive"
                                     Color="Color.Primary" />
                    </MudItem>
                </MudGrid>
                <MudDivider Class="my-4" />

                <MudText Typo="Typo.subtitle1">
                    Rutas disponibles
                </MudText>

                <MudTable Items="_model.Routes"
                          Dense="true"
                          Hover="true"
                          Bordered="true">
                    <HeaderContent>
                        <MudTh>Asignar</MudTh>
                        <MudTh>Ruta</MudTh>
                        <MudTh>Valor agencia</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd>
                            <MudCheckBox T="bool"
                                         @bind-Value="context.IsSelected"
                                         Color="Color.Primary" />
                        </MudTd>

                        <MudTd>@context.RouteName</MudTd>

                        <MudTd>
                            <MudNumericField T="decimal"
                                             @bind-Value="context.Value"
                                             Disabled="@(!context.IsSelected)"
                                             Min="0"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Adornment="Adornment.Start"
                                             AdornmentText="$" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudForm>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">
            Cancelar
        </MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="_saving"
                   OnClick="Save">
            @(_saving ? "Guardando..." : "Guardar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid? Id { get; set; }

    private AgencyEditModel _model = new()
    {
        IsActive = true
    };

    private MudForm? _form;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var data = await Service.GetAsync(Id.Value);

            if (data is not null)
                _model = data;
        }
        else
        {
            _model = await Service.NewAsync();
        }
    }

    private async Task Save()
    {
        if (_form is null)
            return;

        await _form.Validate();

        if (!_form.IsValid)
            return;

        _saving = true;

        try
        {
            await Service.SaveAsync(_model);

            Snackbar.Add("Agencia guardada correctamente.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}