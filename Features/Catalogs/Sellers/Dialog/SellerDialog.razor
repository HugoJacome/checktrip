@using MudBlazor

@inject SellerService Service
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>

        <MudStack Spacing="3">

            <MudText Typo="Typo.subtitle1">
                Datos del vendedor
            </MudText>

            <MudForm @ref="_form">

                <MudStack Spacing="3">

                    <MudTextField T="string"
                                  Label="Nombre"
                                  @bind-Value="_model.FirstName"
                                  Required="true"
                                  RequiredError="El nombre es obligatorio."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />

                    <MudTextField T="string"
                                  Label="Apellido"
                                  @bind-Value="_model.LastName"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />

                    <MudCheckBox T="bool"
                                 Label="Activo"
                                 @bind-Value="_model.IsActive"
                                 Color="Color.Primary" />

                </MudStack>

            </MudForm>

        </MudStack>

    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">
            Cancelar
        </MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="_saving"
                   OnClick="Save">
            @(_saving ? "Guardando..." : "Guardar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid? Id { get; set; }

    private SellerEditModel _model = new()
    {
        IsActive = true
    };

    private MudForm? _form;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var data = await Service.GetAsync(Id.Value);

            if (data is not null)
                _model = data;
        }
    }

    private async Task Save()
    {
        if (_form is null)
            return;

        await _form.Validate();

        if (!_form.IsValid)
            return;

        _saving = true;

        try
        {
            await Service.SaveAsync(_model);

            Snackbar.Add("Vendedor guardado correctamente.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}