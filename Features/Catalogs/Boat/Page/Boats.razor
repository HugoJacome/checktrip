@page "/boats"
@using CheckAccess.Features.Catalogs.Boat.Dialog
@using MudBlazor
@inject BoatService Service
@inject IDialogService Dialog

<MudText Typo="Typo.h5">Botes</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="New">
    Nuevo Bote
</MudButton>

<MudTable T="BoatListItem" Items="_items" Dense="true" Hover="true">
    <HeaderContent>
        <MudTh>Nombre</MudTh>
        <MudTh>Capacidad</MudTh>
        <MudTh>Extra</MudTh>
        <MudTh>Agencia</MudTh>
        <MudTh></MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.Capacity</MudTd>
        <MudTd>@context.ExtraCapacity</MudTd>
        <MudTd>@context.AgencyName</MudTd>

        <MudTd>
            <MudButton Size="Size.Small" OnClick="@(() => Edit(context.Id))">Editar</MudButton>
            <MudButton Size="Size.Small" Color="Color.Error" OnClick="@(() => Delete(context.Id))">Eliminar</MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<BoatListItem> _items = new();

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _items = await Service.GetAllAsync();
    }

    private async Task New()
    {
        await Dialog.ShowAsync<BoatsDialog>("Nuevo Bote");
        await Load();
    }

    private async Task Edit(Guid id)
    {
        var parameters = new DialogParameters { ["Id"] = id };
        await Dialog.ShowAsync<BoatsDialog>("Editar Bote", parameters);
        await Load();
    }

    private async Task Delete(Guid id)
    {
        await Service.DeleteAsync(id);
        await Load();
    }
}