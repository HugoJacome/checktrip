@page "/boats"

@using CheckAccess.Features.Catalogs.Boat.Dialog
@using MudBlazor

@inject BoatService Service
@inject IDialogService Dialog

<MudStack Spacing="3" Style="height: calc(100vh - 96px); min-height:0;">

    <MudStack Row="true"
              AlignItems="AlignItems.Center"
              Justify="Justify.SpaceBetween">

        <MudText Typo="Typo.h5">Botes</MudText>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="New">
            Nuevo bote
        </MudButton>

    </MudStack>

    <MudPaper Class="pa-4 d-flex flex-column"
              Elevation="1"
              Style="flex: 1; min-height: 0; overflow: hidden;">

        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Justify="Justify.SpaceBetween"
                  Class="mb-4">

            <MudText Typo="Typo.subtitle1">Listado de botes</MudText>

            <MudTextField T="string"
                          Value="_search"
                          ValueChanged="OnSearchChanged"
                          Placeholder="Buscar..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Clearable="true"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="max-width: 320px;" />

        </MudStack>

        <MudTable T="BoatListItem"
                  Items="_items"
                  Dense="true"
                  Hover="true"
                  Bordered="true"
                  Striped="true"
                  Loading="_loading"
                  Filter="FilterFunc"
                  SortLabel="Ordenar por"
                  FixedHeader="true"
                  Height="calc(100vh - 330px)"
                  RowsPerPage="10"
                  Class="ct-table-with-pager">

            <HeaderContent>
                <MudTh>
                    <MudTableSortLabel T="BoatListItem" SortBy="x => x.Name">
                        Nombre
                    </MudTableSortLabel>
                </MudTh>

                <MudTh>
                    <MudTableSortLabel T="BoatListItem" SortBy="x => x.Capacity">
                        Capacidad
                    </MudTableSortLabel>
                </MudTh>

                <MudTh>
                    <MudTableSortLabel T="BoatListItem" SortBy="x => x.ExtraCapacity">
                        Extra
                    </MudTableSortLabel>
                </MudTh>

                <MudTh Style="width:160px; text-align:right;">
                    Acciones
                </MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="Nombre">@context.Name</MudTd>
                <MudTd DataLabel="Capacidad">@context.Capacity</MudTd>
                <MudTd DataLabel="Extra">@context.ExtraCapacity</MudTd>

                <MudTd DataLabel="Acciones" Class="text-end">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="@(() => Edit(context.Id))" />

                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => Delete(context.Id))" />
                </MudTd>
            </RowTemplate>

            <NoRecordsContent>
                <MudText Class="pa-4">No existen botes registrados.</MudText>
            </NoRecordsContent>

            <LoadingContent>
                <MudText Class="pa-4">Cargando botes...</MudText>
            </LoadingContent>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>

        </MudTable>

    </MudPaper>

</MudStack>

<style>
    .ct-table-with-pager {
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

        .ct-table-with-pager .mud-table-container {
            flex: 1;
            min-height: 0;
        }

        .ct-table-with-pager .mud-table-pagination {
            flex-shrink: 0;
            border-top: 1px solid #e0e0e0;
            background: white;
        }
</style>

@code {
    private bool _loading = true;
    private string _search = string.Empty;
    private List<BoatListItem> _items = new();

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;

        try
        {
            _items = await Service.GetAllAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnSearchChanged(string value)
    {
        _search = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private bool FilterFunc(BoatListItem item)
    {
        if (string.IsNullOrWhiteSpace(_search))
            return true;

        return Contains(item.Name) ||
               item.Capacity.ToString().Contains(_search, StringComparison.OrdinalIgnoreCase) ||
               item.ExtraCapacity.ToString().Contains(_search, StringComparison.OrdinalIgnoreCase);
    }

    private bool Contains(string? value)
    {
        return value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;
    }

    private async Task New()
    {
        var options = new DialogOptions
        {
            CloseButton = true,
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true
        };

        var dialog = await Dialog.ShowAsync<BoatsDialog>(
            "Nuevo bote",
            options);

        var result = await dialog.Result;

        if (!result.Canceled)
            await Load();
    }

    private async Task Edit(Guid id)
    {
        var parameters = new DialogParameters
        {
            ["Id"] = id
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true
        };

        var dialog = await Dialog.ShowAsync<BoatsDialog>(
            "Editar bote",
            parameters,
            options);

        var result = await dialog.Result;

        if (!result.Canceled)
            await Load();
    }

    private async Task Delete(Guid id)
    {
        await Service.DeleteAsync(id);
        await Load();
    }
}