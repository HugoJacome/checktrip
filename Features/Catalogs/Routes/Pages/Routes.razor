@page "/routes"

@using CheckAccess.Features.Security
@using MudBlazor
@using CheckAccess.Features.Catalogs.Routes.Dialog

@inject RouteService Service
@inject IDialogService Dialog

<RequirePermission ResourceCode="catalog.routes">

    <MudStack Spacing="3" Style="height: calc(100vh - 96px); min-height:0;">

        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Justify="Justify.SpaceBetween">

            <MudText Typo="Typo.h5">Rutas</MudText>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="New">
                Nueva Ruta
            </MudButton>

        </MudStack>

        <MudPaper Class="pa-4 d-flex flex-column"
                  Elevation="1"
                  Style="flex: 1; min-height: 0; overflow: hidden;">

            <MudStack Row="true"
                      AlignItems="AlignItems.Center"
                      Justify="Justify.SpaceBetween"
                      Class="mb-4">

                <MudText Typo="Typo.subtitle1">Listado de rutas</MudText>

                <MudTextField T="string"
                              Value="_search"
                              ValueChanged="OnSearchChanged"
                              Placeholder="Buscar..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              Clearable="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Style="max-width: 320px;" />

            </MudStack>

            <MudTable T="RouteListItem"
                      Items="_items"
                      Dense="true"
                      Hover="true"
                      Bordered="true"
                      Striped="true"
                      Loading="_loading"
                      Filter="FilterFunc"
                      SortLabel="Ordenar por"
                      FixedHeader="true"
                      Height="calc(100vh - 330px)"
                      RowsPerPage="10"
                      Class="ct-table-with-pager">

                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel T="RouteListItem" SortBy="x => x.Origin">
                            Origen
                        </MudTableSortLabel>
                    </MudTh>

                    <MudTh>
                        <MudTableSortLabel T="RouteListItem" SortBy="x => x.Destination">
                            Destino
                        </MudTableSortLabel>
                    </MudTh>

                    <MudTh>
                        <MudTableSortLabel T="RouteListItem" SortBy="x => x.Description">
                            Descripción
                        </MudTableSortLabel>
                    </MudTh>

                    <MudTh Style="width: 180px; text-align: right;">
                        Acciones
                    </MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="Origen">@context.Origin</MudTd>
                    <MudTd DataLabel="Destino">@context.Destination</MudTd>
                    <MudTd DataLabel="Descripción">@context.Description</MudTd>

                    <MudTd DataLabel="Acciones" Class="text-end">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="@(() => Edit(context.Id))" />

                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => Delete(context.Id))" />
                    </MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <MudText Class="pa-4">No existen rutas registradas.</MudText>
                </NoRecordsContent>

                <LoadingContent>
                    <MudText Class="pa-4">Cargando rutas...</MudText>
                </LoadingContent>

                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </PagerContent>

            </MudTable>

        </MudPaper>

    </MudStack>

</RequirePermission>

<style>
    .ct-table-with-pager {
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

        .ct-table-with-pager .mud-table-container {
            flex: 1;
            min-height: 0;
        }

        .ct-table-with-pager .mud-table-pagination {
            flex-shrink: 0;
            border-top: 1px solid #e0e0e0;
            background: white;
        }
</style>

@code {
    private List<RouteListItem> _items = new();
    private bool _loading = true;
    private string _search = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;

        try
        {
            _items = await Service.GetAllAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnSearchChanged(string value)
    {
        _search = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private bool FilterFunc(RouteListItem item)
    {
        if (string.IsNullOrWhiteSpace(_search))
            return true;

        return Contains(item.Origin) ||
               Contains(item.Destination) ||
               Contains(item.Description);
    }

    private bool Contains(string? value)
    {
        return value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;
    }

    private async Task New()
    {
        var dialog = await Dialog.ShowAsync<RouteDialog>("Nueva Ruta");
        var result = await dialog.Result;

        if (!result.Canceled)
            await Load();
    }

    private async Task Edit(Guid id)
    {
        var parameters = new DialogParameters
        {
            ["Id"] = id
        };

        var dialog = await Dialog.ShowAsync<RouteDialog>("Editar Ruta", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
            await Load();
    }

    private async Task Delete(Guid id)
    {
        await Service.DeleteAsync(id);
        await Load();
    }
}