@inherits LayoutComponentBase

@using MudBlazor
@using CheckTrip.Web.Features.Security.Services
@using CheckTrip.Web.Features.Security.Models

@inject AuthService AuthService
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!_loaded)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_user is null && IsLoginPage)
{
    @Body
}
else if (_user is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudLayout Class="ct-layout">

        <MudDrawer @bind-Open="_drawerOpen"
                   Variant="DrawerVariant.Responsive"
                   Elevation="0"
                   Width="280px"
                   Class="ct-drawer">

            <div class="ct-drawer-logo">
                <div class="ct-drawer-brand">
                    CHECK<span>TRIP</span>
                </div>
                <div class="ct-drawer-subtitle">
                    SISTEMA DE GESTIÓN
                </div>
            </div>

            @* <MudDivider Class="ct-drawer-divider" /> *@

            <NavMenu />
        </MudDrawer>

        <MudAppBar Elevation="0" Class="ct-appbar">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           OnClick="@ToggleDrawer"
                           Class="ct-menu-button" />

            <MudText Typo="Typo.h5" Class="ct-appbar-logo">
                CHECKTRIP
            </MudText>

            <MudSpacer />

            <MudIconButton Icon="@(_isDarkMode? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="ToggleTheme"
                           Class="ct-top-icon" />

            <MudText Typo="Typo.body1" Class="ct-user-name">
                @_user.FullName
            </MudText>

            <MudButton Color="Color.Inherit"
                       Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.Logout"
                       OnClick="Logout"
                       Class="ct-logout-button">
                Salir
            </MudButton>
        </MudAppBar>

        <MudMainContent Class="ct-main-content">
            <MudContainer MaxWidth="MaxWidth.False" Class="ct-page-container">
                @Body
            </MudContainer>
        </MudMainContent>

    </MudLayout>
}

@code {
    private bool _loaded;
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private CurrentUserModel? _user;

    private bool IsLoginPage =>
        Navigation.Uri.Contains("/login", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _user = await AuthService.GetCurrentUserAsync();

        if (_user is null && !IsLoginPage)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        _loaded = true;
        StateHasChanged();
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#4f6fa9",
            Secondary = "#3f4143",
            AppbarBackground = "#4f6fa9",
            AppbarText = "#ffffff",
            DrawerBackground = "#3f4143",
            DrawerText = "#ffffff",
            DrawerIcon = "#ffffff",
            Background = "#f4f6fb",
            Surface = "#ffffff",
            TextPrimary = "#3f4143",
            TextSecondary = "#6c757d",
            ActionDefault = "#4f6fa9",
            Divider = "#5a5c5f"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#4f6fa9",
            Secondary = "#3f4143",
            AppbarBackground = "#4f6fa9",
            AppbarText = "#ffffff",
            DrawerBackground = "#3f4143",
            DrawerText = "#ffffff",
            DrawerIcon = "#ffffff",
            Background = "#11151c",
            Surface = "#1b202b",
            TextPrimary = "#ffffff",
            TextSecondary = "#c7c7c7",
            ActionDefault = "#7f95d1",
            Divider = "#2e3442"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Barlow", "Arial", "sans-serif" },
                FontWeight = "400"
            },
            H5 = new H5Typography
            {
                FontFamily = new[] { "Barlow", "Arial", "sans-serif" },
                FontWeight = "800"
            },
            H6 = new H6Typography
            {
                FontFamily = new[] { "Barlow", "Arial", "sans-serif" },
                FontWeight = "800"
            },
            Button = new ButtonTypography
            {
                FontFamily = new[] { "Barlow", "Arial", "sans-serif" },
                FontWeight = "700",
                TextTransform = "none"
            }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "14px"
        }
    };
}